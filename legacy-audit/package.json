{
  "name": "rez-workspace",
  "version": "1.0.0",
  "description": "REZ Workspace - Work & Productivity Platform",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "docker:build": "docker build -t rez-workspace:latest .",
    "docker:run": "docker run -d -p 4300:4300 --name rez-workspace rez-workspace:latest",
    "docker:compose": "docker-compose up -d",
    "docker:compose:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:logs": "docker-compose logs -f",
    "clean": "rm -rf dist coverage",
    "prepare": "npm run build"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "axios": "^1.6.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.2",
    "date-fns": "^2.30.0",
    "mongoose": "^8.0.0",
    "redis": "^4.6.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.0",
    "zod": "^3.22.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.15",
    "@types/ws": "^8.5.8",
    "@types/uuid": "^9.0.6",
    "@types/node": "^20.9.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/supertest": "^6.0.0",
    "typescript": "^5.2.2",
    "tsx": "^4.1.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "supertest": "^6.3.0",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "workspace",
    "collaboration",
    "productivity",
    "ai",
    "chat",
    "meetings",
    "tasks"
  ],
  "author": "RTNM Digital",
  "license": "PROPRIETARY"
}