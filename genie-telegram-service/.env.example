# Environment Variables for GENIE Telegram Service

# Server Configuration
PORT=4710
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/genie-telegram

# CORS Origins (comma-separated)
CORS_ORIGINS=*

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com
WEBHOOK_SECRET_TOKEN=your_webhook_secret_here

# GENIE Service URLs (for integration)
GENIE_MEMORY_SERVICE_URL=http://localhost:4703
GENIE_RELATIONSHIP_SERVICE_URL=http://localhost:4702
GENIE_BRIEFING_SERVICE_URL=http://localhost:4704
AUTH_SERVICE_URL=http://localhost:4002

# Internal Token (for service-to-service communication)
INTERNAL_TOKEN=your_internal_token_here
