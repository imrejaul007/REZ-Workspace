# HOJAI Shift Handover Service Configuration
# Copy this file to .env and update values

# Server Configuration
PORT=4603
NODE_ENV=development
CORS_ORIGIN=*

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/shift-handover

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Logging Configuration
LOG_DIR=logs

# Rate Limiting Configuration
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# Notification Service Configuration (optional)
# PUSH_NOTIFICATION_KEY=your-fcm-key
# EMAIL_SERVICE_KEY=your-email-api-key
# SMS_SERVICE_KEY=your-twilio-key
# WHATSAPP_SERVICE_KEY=your-whatsapp-key
