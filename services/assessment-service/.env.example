# Service Configuration
NODE_ENV=development
PORT=4605
SERVICE_NAME=hojai-assessment-service

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/hojai-assessment
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_REPLICA_SET=
MONGODB_AUTH_SOURCE=admin

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI Configuration (for trend analysis insights)
OPENAI_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Service URLs
AUTH_SERVICE_URL=http://localhost:4002
NOTIFICATION_SERVICE_URL=http://localhost:4011
