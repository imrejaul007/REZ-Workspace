# Service Configuration
PORT=4597
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/nextstep

# OpenAI for AI extraction (optional - falls back to rule-based if not set)
OPENAI_API_KEY=sk-your-openai-api-key

# WhatsApp Integration (Notifications Service)
WHATSAPP_API_URL=http://localhost:4011/api/whatsapp/send
WHATSAPP_API_KEY=your-whatsapp-api-key

# SMS Integration
SMS_API_URL=http://localhost:4011/api/sms/send
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=REZAI

# Email Integration
EMAIL_API_URL=http://localhost:4011/api/email/send
EMAIL_API_KEY=your-email-api-key

# Push Notifications
PUSH_API_URL=http://localhost:4011/api/push/send
PUSH_API_KEY=your-push-api-key

# Notification Service (fallback)
NOTIFICATION_SERVICE_URL=http://localhost:4011

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:4000

# Frontend URL for email links
FRONTEND_URL=https://app.rez.ai

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Demo Mode (for testing without real contacts)
DEMO_MODE=false
