# Voice AI Service Environment Variables
PORT=4590
NODE_ENV=development

# Speech-to-Text Provider
STT_PROVIDER=whisper  # whisper, google, assemblyai
WHISPER_API_KEY=
GOOGLE_SPEECH_API_KEY=
ASSEMBLYAI_API_KEY=

# Text-to-Speech Provider
TTS_PROVIDER=elevenlabs  # elevenlabs, google, cartesia
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Medical NLP
MEDICAL_NLP_ENABLED=true
OPENAI_API_KEY=

# Transcription Settings
MAX_AUDIO_DURATION_SECONDS=3600
SUPPORTED_AUDIO_FORMATS=mp3,wav,m4a,ogg,webm

# Storage
STORAGE_PROVIDER=local  # local, s3
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Logging
LOG_LEVEL=info
