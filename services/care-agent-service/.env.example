# HOJAI Care Agent Service Environment Variables

# Server Configuration
PORT=4592
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/hojai_care

# AI/ML Services
OPENAI_API_KEY=sk-your-openai-api-key-here

# HOJAI Internal Services
MEMORY_SERVICE_URL=http://localhost:4591
VOICE_SERVICE_URL=http://localhost:4590
EVALUATION_SERVICE_URL=http://localhost:4591

# RisaCare Integration
RISACARE_API_URL=http://localhost:4701

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_TTL_SECONDS=3600
MAX_CHAT_HISTORY=50
