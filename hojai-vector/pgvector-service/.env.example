# HOJAI pgvector Service Environment Variables

# Service Configuration
PORT=4721
NODE_ENV=development

# Database Configuration (PostgreSQL with pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hojai_vector
PGHOST=localhost
PGPORT=5432
PGDATABASE=hojai_vector
PGUSER=postgres
PGPASSWORD=postgres

# CORS Configuration
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
