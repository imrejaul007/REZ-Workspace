# HOJAI AI Support Agent - Environment Variables
# Version: 1.0.0 | Date: May 30, 2026

# Server Configuration
PORT=4760
NODE_ENV=development

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Database (for production)
# MONGODB_URI=mongodb://localhost:27017/ai-support-agent

# Redis (for production caching)
# REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info

# Internal Service Token (for service-to-service communication)
# INTERNAL_SERVICE_TOKEN=your-internal-service-token

# External Service URLs
# AUTH_SERVICE_URL=http://localhost:4002
# PAYMENT_SERVICE_URL=http://localhost:4001
# ORDER_SERVICE_URL=http://localhost:4006

# AI Configuration
# AI_MODEL_PROVIDER=openai
# AI_API_KEY=your-api-key

# Warranty Service Integration
# WARRANTY_SERVICE_URL=http://localhost:4761

# Refund Configuration
REFUND_AUTO_APPROVE_LIMIT=1000
REFUND_MAX_AMOUNT=100000

# Support Configuration
SUPPORT_EMAIL=support@example.com
SUPPORT_PHONE=1800-XXX-XXXX

# SLA Configuration (in hours)
SLA_URGENT_FIRST_RESPONSE=1
SLA_URGENT_RESOLUTION=4
SLA_HIGH_FIRST_RESPONSE=4
SLA_HIGH_RESOLUTION=24
SLA_MEDIUM_FIRST_RESPONSE=8
SLA_MEDIUM_RESOLUTION=48
SLA_LOW_FIRST_RESPONSE=24
SLA_LOW_RESOLUTION=72
