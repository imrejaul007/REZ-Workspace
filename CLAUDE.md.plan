  "integrations": {
    "unified-hub": "http://localhost:4600",
    "hojai-memory": "http://localhost:4520",
    "hojai-agents": "http://localhost:4550",
    "rabtul-auth": "https://rez-auth-service.onrender.com",
    "rabtul-wallet": "https://rez-wallet-service.onrender.com",
    "rabtul-booking": "https://rez-booking-service.onrender.com"
  }
}
```

