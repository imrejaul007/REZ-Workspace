# RTMN Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# LLM API KEYS (Optional - Demo mode works without)
# ===========================================

# OpenAI API Key (for GPT-4 powered responses)
# Get your key at: https://platform.openai.com/api-keys
LLM_API_KEY=sk-your-openai-key-here

# Anthropic API Key (for Claude powered responses)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Local LLM (optional - for self-hosted models)
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3

# ===========================================
# DATABASE (Optional - for persistent storage)
# ===========================================

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/rtmn
MONGODB_USERNAME=rtmn
MONGODB_PASSWORD=your-mongodb-password

# ===========================================
# REDIS (Optional - for event bus & caching)
# ===========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# ===========================================
# AUTHENTICATION (for production)
# ===========================================

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# ===========================================
# EXTERNAL SERVICES
# ===========================================

# RABTUL Auth Service
RABTUL_API_URL=http://localhost:4001
RABTUL_API_KEY=your-rabtul-api-key

# Nexha Commerce
NEXHA_API_URL=http://localhost:4003
NEXHA_API_KEY=your-nexha-api-key

# AdBazaar Media
ADBazaar_API_URL=http://localhost:4004
ADBazaar_API_KEY=your-adbazaar-api-key

# ===========================================
# LOGGING
# ===========================================

LOG_LEVEL=info
LOG_FORMAT=json

# ===========================================
# CORS
# ===========================================

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
