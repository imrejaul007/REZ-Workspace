# Server Configuration
NODE_ENV=development
PORT=4809

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/tripmind

# JWT Configuration
JWT_SECRET=tripmind_super_secret_key_change_in_production_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Agent Configuration
AI_TRIP_PLANNER_ENABLED=true
AI_BOOKING_AGENT_ENABLED=true
AI_VISA_AGENT_ENABLED=true
AI_AIRPORT_AGENT_ENABLED=true

# External API Keys (Optional)
FLIGHT_API_KEY=
HOTEL_API_KEY=
WEATHER_API_KEY=

# Logging
LOG_LEVEL=info

# Security
CORS_ORIGIN=*