{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "./services/*": ["services/*"],
      "./employees/*": ["employees/*"],
      "./voice-agents/*": ["voice-agents/*"],
      "./connectors/*": ["connectors/*"]
    }
  },
  "include": [
    "src/**/*",
    "services/**/*",
    "employees/**/*",
    "voice-agents/**/*",
    "connectors/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}