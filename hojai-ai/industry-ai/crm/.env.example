# HOJAI Industry CRM - Cross-Industry CRM Platform
# Copy this file to .env and update values

# ============================================
# SERVER CONFIGURATION
# ============================================

PORT=4980
NODE_ENV=development
HOST=0.0.0.0

# ============================================
# MONGODB CONFIGURATION
# ============================================

MONGODB_URI=mongodb://localhost:27017/hojai_crm
MONGO_TIMEOUT=5000
MONGO_SOCKET_TIMEOUT=45000
MONGO_POOL_SIZE=10

# ============================================
# JWT AUTHENTICATION
# ============================================

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS
# ============================================

CORS_ORIGIN=*

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=info
LOG_DIR=logs

# ============================================
# ECOSYSTEM SERVICES (Optional)
# ============================================

# HOJAI Core
HOJAI_URL=http://localhost:4800

# RABTUL Services
AUTH_SERVICE_URL=http://localhost:4002
NOTIFICATION_SERVICE_URL=http://localhost:4011

# Industry AI Products
WAITRON_URL=http://localhost:4620
STAYBOT_URL=http://localhost:4621
GLAMAI_URL=http://localhost:4622
FITMIND_URL=http://localhost:4623
SHOPFLOW_URL=http://localhost:4624
LEDGERAI_URL=http://localhost:4625
FLEETIQ_URL=http://localhost:4626
NEIGHBORAI_URL=http://localhost:4627
CARECODE_URL=http://localhost:4628
GROCERYIQ_URL=http://localhost:4131
AUTOMIND_URL=http://localhost:4132
EDULEARN_URL=http://localhost:4133
FRANCHISEAII_URL=http://localhost:4058