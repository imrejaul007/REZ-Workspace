  "author": "HOJAI AI",
  "license": "MIT",
  "dependencies": {
    "@hojai/agent-runtime": "file:../../hojai-agent-runtime",
    "@anthropic-ai/sdk": "^0.27.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "uuid": "^10.0.0",
