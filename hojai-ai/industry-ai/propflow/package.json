  "description": "PROPFLOW - Real Estate AI Operating System | AI-powered property management, lead qualification, and deal closure",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
