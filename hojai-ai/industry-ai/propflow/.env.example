# PROPFLOW - Real Estate AI Operating System
# Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=4807

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/propflow
MONGODB_USER=
MONGODB_PASSWORD=

# JWT Configuration
JWT_SECRET=propflow-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Redis Configuration (optional, for caching)
REDIS_URL=redis://localhost:6379

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_DIR=logs

# AI Configuration
AI_PROPERTY_MATCH_THRESHOLD=60
AI_LEAD_QUALIFY_THRESHOLD=50

# LLM Configuration (for AI agents - uses Claude)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.7

# Agent Runtime
HOJAI_RUNTIME_URL=http://localhost:4700

# Internal Service Token (for service-to-service communication)
INTERNAL_SERVICE_TOKEN=propflow-internal-token-change-in-production

# Email Configuration (for notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@propflow.ai

# SMS Configuration (for notifications)
SMS_API_KEY=
SMS_API_SECRET=

# ============================================
# INTEGRATIONS - REZ ECOSYSTEM
# ============================================

# HOJAI AI Services
HOJAI_URL=http://localhost:4800
HOJAI_MEMORY_URL=http://localhost:4540

# RABTUL Technologies (Auth, Wallet, Payment)
RABTUL_AUTH_URL=http://localhost:4101
RABTUL_WALLET_URL=http://localhost:4102
RABTUL_PAYMENT_URL=http://localhost:4103
RABTUL_NOTIFICATION_URL=http://localhost:4095

# Webhook Service
WEBHOOK_SERVICE_URL=http://localhost:4090

# ============================================
# REDIS (Alternative Configuration)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379