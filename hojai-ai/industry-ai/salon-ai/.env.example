# Salon AI - Salon & Beauty Industry AI Operating System
# Port: 4870
# Production-ready with MongoDB support

# Server Configuration
PORT=4870
NODE_ENV=development

# MongoDB Configuration (REQUIRED for production)
MONGODB_URI=mongodb://localhost:27017/salon_ai
# Or use MONGO_URL (alternative)
# MONGO_URL=mongodb://localhost:27017/salon_ai

# Logging
LOG_LEVEL=info

# CORS (comma-separated origins for production)
CORS_ORIGIN=*

# Security
INTERNAL_SERVICE_TOKEN=hojai-dev-token-change-in-production

# Rate Limiting (optional overrides)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# Redis (optional - for session management)
# REDIS_URL=redis://localhost:6379

# HOJAI Integration (optional)
# HOJAI_API_URL=http://localhost:4540
# HOJAI_API_KEY=your-api-key

# RABTUL Integration (optional - for payments)
# RABTUL_API_URL=http://localhost:4000
# RABTUL_API_KEY=your-api-key