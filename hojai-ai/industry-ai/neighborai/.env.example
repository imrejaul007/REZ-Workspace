# ============================================
# NEIGHBORAI Environment Configuration
# ============================================

# Server Configuration
NODE_ENV=development
PORT=4806

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/neighborai

# JWT Configuration
JWT_SECRET=neighborai-super-secret-2024-change-in-production

# Internal Service Token (for service-to-service communication)
INTERNAL_SERVICE_TOKEN=neighborai-internal-service-token-change-in-production

# CORS Configuration
CORS_ORIGIN=*

# Logging Configuration
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Admin Credentials (change these in production!)
ADMIN_EMAIL=admin@neighborai.com
ADMIN_PASSWORD=admin123