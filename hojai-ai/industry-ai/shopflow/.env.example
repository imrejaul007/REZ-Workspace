# SHOPFLOW - Retail AI Operating System

# Server Configuration
PORT=4830
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/shopflow
MONGODB_TIMEOUT=5000
MONGODB_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=shopflow-dev-secret-change-in-production
JWT_EXPIRES_IN=24h

# Security Configuration
INTERNAL_SERVICE_TOKEN=shopflow-internal-dev-token
BCRYPT_ROUNDS=12

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOGS_DIR=logs

# Integration Services
WEBHOOK_SERVICE_URL=http://localhost:4090
HOJAI_URL=http://localhost:4800
NOTIFICATION_SERVICE_URL=http://localhost:4095
INTERNAL_SERVICE_TOKEN=hojai-dev-token

# OpenTelemetry Distributed Tracing
OTEL_SERVICE_NAME=shopflow
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
