# GROCERYIQ - Grocery Retail AI Operating System
# Copy this file to .env and update values

# ============================================
# SERVER CONFIGURATION
# ============================================

PORT=4131
NODE_ENV=development
HOST=0.0.0.0

# ============================================
# MONGODB CONFIGURATION
# ============================================

MONGODB_URI=mongodb://localhost:27017/groceryiq
MONGO_TIMEOUT=5000
MONGO_SOCKET_TIMEOUT=45000
MONGO_POOL_SIZE=10

# ============================================
# AUTHENTICATION
# ============================================

INTERNAL_SERVICE_TOKEN=hojai-dev-token

# ============================================
# ECOSYSTEM SERVICES (Optional)
# ============================================

# HOJAI Core
HOJAI_URL=http://localhost:4800

# RABTUL Services
AUTH_SERVICE_URL=http://localhost:4002
NOTIFICATION_SERVICE_URL=http://localhost:4011

# Webhook & Event Bus
WEBHOOK_SERVICE_URL=http://localhost:4090

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ============================================
# CORS
# ============================================

CORS_ORIGIN=*

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=info
LOG_DIR=logs

# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_WEBHOOKS=true
ENABLE_HOJAI_SYNC=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_AUTO_UPGRADE=false