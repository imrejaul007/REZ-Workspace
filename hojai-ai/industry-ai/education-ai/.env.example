# EDUCATION-AI - Educational Institutions AI Operating System
# Copy this file to .env and update values

# ============================================
# SERVER CONFIGURATION
# ============================================

PORT=4050
NODE_ENV=development
HOST=0.0.0.0

# ============================================
# MONGODB CONFIGURATION
# ============================================

MONGODB_URI=mongodb://localhost:27017/education_ai
MONGO_TIMEOUT=5000
MONGO_SOCKET_TIMEOUT=45000
MONGO_POOL_SIZE=10

# ============================================
# JWT AUTHENTICATION
# ============================================

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS
# ============================================

CORS_ORIGIN=*

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=info
LOG_DIR=logs

# ============================================
# ECOSYSTEM SERVICES (Optional)
# ============================================

# HOJAI Core
HOJAI_URL=http://localhost:4800

# REZ Intelligence
REZ_INTELLIGENCE_URL=http://localhost:4200

# LMS Service
LMS_SERVICE_URL=http://localhost:4734