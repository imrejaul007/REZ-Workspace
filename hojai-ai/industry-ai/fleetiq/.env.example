# FLEETIQ - Environment Configuration

# Server Configuration
PORT=4814
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/fleetiq
MONGODB_TIMEOUT=5000
MONGODB_SOCKET_TIMEOUT=45000
MONGODB_POOL_SIZE=10

# JWT Configuration
JWT_SECRET=fleetiq-dev-secret-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Security Configuration
INTERNAL_SERVICE_TOKEN=fleetiq-internal-dev-token
BCRYPT_ROUNDS=12

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# Logging
LOG_LEVEL=info
LOGS_DIR=logs

# AI Endpoints (for future microservice architecture)
AI_DISPATCH_ENDPOINT=http://localhost:4815
AI_ROUTE_ENDPOINT=http://localhost:4816
AI_FLEET_ENDPOINT=http://localhost:4817
AI_DRIVER_ENDPOINT=http://localhost:4818

# Claude AI Integration
ANTHROPIC_API_KEY=your-anthropic-api-key-here