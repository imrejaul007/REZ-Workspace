# GLAMAI - Environment Variables Example
# Copy this file to .env and update values

# ============================================
# SERVER CONFIGURATION
# ============================================

PORT=4860
NODE_ENV=development
HOST=0.0.0.0

# ============================================
# MONGODB CONFIGURATION
# ============================================

MONGO_URL=mongodb://localhost:27017/glamai
MONGO_TIMEOUT=5000
MONGO_SOCKET_TIMEOUT=45000
MONGO_POOL_SIZE=10

# ============================================
# AUTHENTICATION
# ============================================

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
INTERNAL_TOKEN=your-internal-service-token-change-in-production

# ============================================
# ECOSYSTEM SERVICES (Optional)
# ============================================

# HOJAI Core
HOJAI_URL=http://localhost:4800
HOJAI_ENTERPRISE_BRAIN_URL=http://localhost:4600

# RABTUL Services
AUTH_SERVICE_URL=http://localhost:4002
WALLET_SERVICE_URL=http://localhost:4003
NOTIFICATION_SERVICE_URL=http://localhost:4095

# Webhook & Event Bus
WEBHOOK_SERVICE_URL=http://localhost:4090
EVENT_BUS_URL=http://localhost:4091

# REZ Intelligence
REZ_MIND_URL=http://localhost:4300
INTENT_GRAPH_URL=http://localhost:4301

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_API_WINDOW=900000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_AUTH_WINDOW=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AI_WINDOW=60000
RATE_LIMIT_AI_MAX=30

# ============================================
# CORS
# ============================================

CORS_ORIGIN=*

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=info
LOG_DIR=logs

# ============================================
# BUSINESS HOURS
# ============================================

BUSINESS_START=09:00
BUSINESS_END=21:00
SLOT_INTERVAL=30
ADVANCE_BOOKING_DAYS=30
MIN_CANCELLATION_HOURS=2

# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_WEBHOOKS=true
ENABLE_HOJAI_SYNC=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_AUTO_UPGRADE=false
DEMO_MODE=false