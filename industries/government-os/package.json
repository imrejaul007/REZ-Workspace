{
  "name": "government-os",
  "version": "1.0.0",
  "description": "Government OS - A comprehensive digital government services platform",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.js\"",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "k8s:deploy": "kubectl apply -f deployment/kubernetes/",
    "k8s:undeploy": "kubectl delete -f deployment/kubernetes/",
    "k8s:status": "kubectl get pods -n government-os",
    "k8s:logs": "kubectl logs -n government-os -l app=",
    "docs:api": "apidoc -i services/ -i agents/ -o docs/api/",
    "security:scan": "npm audit --audit-level=moderate",
    "clean": "rm -rf logs/*.log node_modules"
  },
  "keywords": [
    "government",
    "digital-services",
    "citizen-services",
    "permit-system",
    "compliance",
    "twin",
    "government-cloud"
  ],
  "author": "RTMN",
  "license": "MIT",
  "dependencies": {
    "@azure/cosmos": "^4.0.0",
    "@azure/data-tables": "^12.1.6",
    "@azure/service-bus": "^7.9.0",
    "@azure/storage-blob": "^12.16.0",
    "aws-sdk": "^2.1500.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "jsforce": "^1.11.1",
    "jwks-rsa": "^3.1.0",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.11",
    "twilio": "^4.19.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "apidoc": "^1.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rtmn/government-os"
  },
  "bugs": {
    "url": "https://github.com/rtmn/government-os/issues"
  }
}
