# Portfolio Twin Service Environment Variables

# Service Configuration
PORT=8950
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/portfolio_twin

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Authentication
API_KEY=portfolio-twin-api-key
INTERNAL_SERVICE_TOKEN=internal-token

# Service URLs
ASSETMIND_URL=http://localhost:8943
RABTUL_CONNECT_URL=http://localhost:8947
MARKET_INTELLIGENCE_URL=http://localhost:8951
PORTFOLIO_ANALYSIS_URL=http://localhost:8952

# RTNM Gateway
RTNM_GATEWAY_URL=http://localhost:4600

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=info
