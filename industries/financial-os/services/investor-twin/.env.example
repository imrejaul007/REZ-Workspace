# Service Configuration
SERVICE_NAME=investor-twin-service
SERVICE_PORT=4030
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/investor_twin

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URI=amqp://localhost:5672

# External Service URLs
TRADING_SERVICE_URL=http://localhost:4031
PORTFOLIO_SERVICE_URL=http://localhost:4032
RISK_ANALYTICS_SERVICE_URL=http://localhost:4033
MARKET_DATA_SERVICE_URL=http://localhost:4034
REZ_DASHBOARD_SERVICE_URL=http://localhost:4060

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WRITE_MAX=20

# Logging
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:4030
