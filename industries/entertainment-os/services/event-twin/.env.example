# =============================================================================
# ENTERTAINMENT OS - Event Twin Service Environment Variables
# =============================================================================

PORT=8103
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8103

MONGODB_URI=mongodb://localhost:27017/event_twin
MONGODB_USER=admin
MONGODB_PASSWORD=password

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=password

API_KEY=event-twin-api-key-change-in-production
INTERNAL_SERVICE_TOKEN=internal-service-token-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production

LOG_LEVEL=info
