# =============================================================================
# ENTERTAINMENT OS - Content Twin Service Environment Variables
# =============================================================================

# =============================================================================
# SERVER
# =============================================================================
PORT=8105
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8105

# =============================================================================
# DATABASE
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/content_twin
MONGODB_USER=admin
MONGODB_PASSWORD=password

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=password

# =============================================================================
# AUTHENTICATION
# =============================================================================
API_KEY=content-twin-api-key-change-in-production
INTERNAL_SERVICE_TOKEN=internal-service-token-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
