# =============================================================================
# ENTERTAINMENT OS - Environment Variables Template
# =============================================================================

# =============================================================================
# SERVER
# =============================================================================
PORT=8101
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8101

# =============================================================================
# DATABASE
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/audience_twin
MONGODB_USER=admin
MONGODB_PASSWORD=password

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=password

# =============================================================================
# AUTHENTICATION
# =============================================================================
API_KEY=audience-twin-api-key-change-in-production
INTERNAL_SERVICE_TOKEN=internal-service-token-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production

# =============================================================================
# BRANDPULSE INTEGRATION
# =============================================================================
BRANDPULSE_URL=http://localhost:7001
BRANDPULSE_API_KEY=brandpulse-api-key

# =============================================================================
# INTENT EXCHANGE INTEGRATION
# =============================================================================
INTENT_EXCHANGE_URL=http://localhost:7002
INTENT_EXCHANGE_API_KEY=intent-exchange-api-key

# =============================================================================
# VENUE TWIN SERVICE
# =============================================================================
VENUE_TWIN_URL=http://localhost:8102

# =============================================================================
# EVENT TWIN SERVICE
# =============================================================================
EVENT_TWIN_URL=http://localhost:8103

# =============================================================================
# CREATOR TWIN SERVICE
# =============================================================================
CREATOR_TWIN_URL=http://localhost:8104

# =============================================================================
# CONTENT TWIN SERVICE
# =============================================================================
CONTENT_TWIN_URL=http://localhost:8105

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
