# =============================================================================
# ENTERTAINMENT OS - Venue Twin Service Environment Variables
# =============================================================================

# =============================================================================
# SERVER
# =============================================================================
PORT=8102
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8102

# =============================================================================
# DATABASE
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/venue_twin
MONGODB_USER=admin
MONGODB_PASSWORD=password

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=password

# =============================================================================
# AUTHENTICATION
# =============================================================================
API_KEY=venue-twin-api-key-change-in-production
INTERNAL_SERVICE_TOKEN=internal-service-token-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production

# =============================================================================
# DOOH NETWORK INTEGRATION
# =============================================================================
DOOH_NETWORK_URL=http://localhost:7003
DOOH_NETWORK_API_KEY=dooh-network-api-key

# =============================================================================
# AUDIENCE TWIN SERVICE
# =============================================================================
AUDIENCE_TWIN_URL=http://localhost:8101

# =============================================================================
# EVENT TWIN SERVICE
# =============================================================================
EVENT_TWIN_URL=http://localhost:8103

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
