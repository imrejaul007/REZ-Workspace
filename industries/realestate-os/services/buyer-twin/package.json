{
  "name": "@rtmn/buyer-twin",
  "version": "1.0.0",
  "description": "RTMN Buyer Twin - Real estate buyer profiles and matching for TwinOS",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
