# Property Twin Service Environment Variables

# Service Configuration
PORT=8843
NODE_ENV=development
HOST=0.0.0.0
SERVICE_NAME=property-twin-service

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/property-twin-service

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_URI=amqp://localhost:5672

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Service URLs (for inter-service communication)
PROPFLOW_SERVICE_URL=http://localhost:8844
MARKETPLACE_SERVICE_URL=http://localhost:8845
LEAD_SERVICE_URL=http://localhost:8846
INVESTMENT_SERVICE_URL=http://localhost:8847
VIRTUAL_TOURS_SERVICE_URL=http://localhost:8848
BROKER_NETWORK_SERVICE_URL=http://localhost:8849
GOLDEN_VISA_SERVICE_URL=http://localhost:8850
REFERRALS_SERVICE_URL=http://localhost:8851