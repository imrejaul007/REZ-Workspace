# RTMN Agent Twin Service Environment Variables

# Server Configuration
PORT=8848
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/agent_twin

# Redis Configuration (optional - for distributed event emission)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=password

# Security
API_KEY=agent-twin-api-key
INTERNAL_SERVICE_TOKEN=your-internal-service-token
JWT_SECRET=your-jwt-secret

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8848

# Logging
LOG_LEVEL=info