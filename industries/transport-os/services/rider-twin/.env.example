# Environment Variables for Rider Twin Service

# Server Configuration
NODE_ENV=development
PORT=9050

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:9050

# Logging
LOG_LEVEL=info

# External Services
EVENT_BUS_URL=http://localhost:4025
TWINOS_URL=http://localhost:4142

# Security (generate a secure secret in production)
JWT_SECRET=your-secret-key-here
