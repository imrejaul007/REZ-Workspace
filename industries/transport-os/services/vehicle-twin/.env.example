# Vehicle Twin Service Environment Configuration

# Service Configuration
SERVICE_NAME=vehicle-twin
SERVICE_PORT=9041
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/vehicle_twin

# Redis Configuration
REDIS_URL=redis://localhost:6379

# RabbitMQ Configuration
RABBITMQ_URI=amqp://localhost:5672

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:9040,http://localhost:9044,http://localhost:9050
