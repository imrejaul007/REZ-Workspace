# Driver Twin Service Environment Configuration
# Copy to .env and configure for your environment

# Service Configuration
PORT=9047
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/driver_twin
MONGODB_USER=admin
MONGODB_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=password

# Service-to-Service Authentication
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here
API_KEY=driver-twin-api-key

# RTMN Gateway
RTNM_GATEWAY_URL=http://localhost:4600

# Transport OS Services
KHAIRMOVE_FLEET_URL=http://localhost:9044
KHAIRMOVE_DRIVER_URL=http://localhost:9047
DISPATCH_SERVICE_URL=http://localhost:9046
VEHICLE_TWIN_URL=http://localhost:9044
FLEET_TWIN_URL=http://localhost:9045

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=info
