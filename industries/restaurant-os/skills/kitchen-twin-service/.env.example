# Kitchen Twin Service Environment Configuration

SERVICE_NAME=kitchen-twin-service
SERVICE_PORT=4015
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/kitchen_twin_service

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URI=amqp://localhost:5672

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
