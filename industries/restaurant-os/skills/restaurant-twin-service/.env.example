# Restaurant Twin Service Environment Configuration

# Service
SERVICE_NAME=restaurant-twin-service
SERVICE_PORT=4011
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/restaurant_twin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URI=amqp://localhost:5672

# REZ Services
REZ_POS_SERVICE_URL=http://localhost:4013
REZ_DASHBOARD_SERVICE_URL=http://localhost:4060

# API Keys
REZ_POS_API_KEY=your-rez-pos-api-key
REZ_DASHBOARD_API_KEY=your-rez-dashboard-api-key

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000,http://localhost:4010,http://localhost:4013,http://localhost:4014,http://localhost:4022,http://localhost:4058,http://localhost:4060,http://localhost:4082,http://localhost:4091

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WRITE_MAX=20

# Logging
LOG_LEVEL=info