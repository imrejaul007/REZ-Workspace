# Room Twin Service Environment Configuration
PORT=8444
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://admin:password@localhost:27017/room-twin?authSource=admin

# Redis Configuration
REDIS_URL=redis://localhost:6379

# MQTT IoT Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Service URLs
GUEST_MEMORY_URL=http://localhost:8447
REZ_POS_URL=http://localhost:8449
REZ_LOYALTY_URL=http://localhost:8450
BRANDPULSE_URL=http://localhost:8451

# Internal Service Token
INTERNAL_SERVICE_TOKEN=room-twin-internal-token-change-in-production

# Logging
LOG_LEVEL=info
