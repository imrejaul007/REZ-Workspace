# Guest Twin Service Environment Configuration
# Copy to .env and configure for your environment

# Service Configuration
PORT=8447
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/guest_twin
MONGODB_USER=admin
MONGODB_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=password

# Service-to-Service Authentication
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here
API_KEY=guest-twin-api-key

# Guest Memory Integration (port 8447)
GUEST_MEMORY_URL=http://localhost:8447
GUEST_MEMORY_API_KEY=your-guest-memory-api-key

# Other Hotel OS Services
REZ_LOYALTY_URL=http://localhost:8450
REZ_POS_URL=http://localhost:8449
BRANDPULSE_URL=http://localhost:8451

# RTNM Gateway
RTNM_GATEWAY_URL=http://localhost:4600

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Logging
LOG_LEVEL=info
