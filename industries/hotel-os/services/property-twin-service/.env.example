# Property Twin Service Environment Configuration
NODE_ENV=development
PORT=8448

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/property-twin-service
MONGODB_USER=
MONGODB_PASSWORD=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URI=amqp://localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Service Configuration
SERVICE_NAME=property-twin-service
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# External Services
GUEST_MEMORY_SERVICE_URL=http://localhost:8447
REZ_POS_SERVICE_URL=http://localhost:8449
REZ_LOYALTY_SERVICE_URL=http://localhost:8450
BRANDPULSE_SERVICE_URL=http://localhost:8451
