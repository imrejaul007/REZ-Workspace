{
  "name": "@rtmn/guest-memory-twinos",
  "version": "1.0.0",
  "description": "Guest Memory Integration with TwinOS Hub for Hotel OS",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "docker:build": "docker build -t rtmn/guest-memory-twinos:latest -f docker/Dockerfile .",
    "docker:run": "docker run -p 8447:8447 rtmn/guest-memory-twinos:latest"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "axios": "^1.6.8",
    "ws": "^8.16.0",
    "ioredis": "^5.3.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.2",
    "ts-node": "^10.9.2",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
