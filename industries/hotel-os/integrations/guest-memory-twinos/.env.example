# Guest Memory TwinOS Integration Environment Variables

# Service Configuration
PORT=8447
NODE_ENV=development
LOG_LEVEL=info

# TwinOS Hub Connection
TWINOS_HUB_URL=http://localhost:4143
TWINOS_API_KEY=your-twinos-api-key

# Security
INTERNAL_SERVICE_TOKEN=your-internal-service-token
API_KEY=your-api-key

# CORS
CORS_ORIGIN=*

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# MongoDB (for persistence)
MONGODB_URI=mongodb://localhost:27017/guest-memory