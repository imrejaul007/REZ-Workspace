# AI Concierge Agent Configuration
NODE_ENV=development
PORT=8452

# Service Discovery
SERVICE_NAME=ai-concierge
SERVICE_VERSION=1.0.0

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Guest Memory Integration (8447)
GUEST_MEMORY_URL=http://localhost:8447
GUEST_MEMORY_TIMEOUT=5000

# REZ POS Integration (8449)
REZ_POS_URL=http://localhost:8449
REZ_POS_TIMEOUT=5000

# REZ Loyalty Integration (8450)
REZ_LOYALTY_URL=http://localhost:8450
REZ_LOYALTY_TIMEOUT=5000

# BrandPulse Integration (8451)
BRAND_PULSE_URL=http://localhost:8451
BRAND_PULSE_TIMEOUT=5000

# TwinOS Integration
TWINOS_URL=http://localhost:3001
TWINOS_TIMEOUT=5000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
