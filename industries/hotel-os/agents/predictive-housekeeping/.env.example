# Service Configuration
PORT=8446
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/predictive_housekeeping
MONGODB_USER=
MONGODB_PASSWORD=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URI=amqp://localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Service Discovery
SERVICE_NAME=predictive-housekeeping
SERVICE_VERSION=1.0.0

# Integration Services
GUEST_MEMORY_URL=http://localhost:8447
TWIN_OS_URL=http://localhost:8080
REZ_POS_URL=http://localhost:8449
REZ_LOYALTY_URL=http://localhost:8450
BRAND_PULSE_URL=http://localhost:8451

# Scheduling Configuration
SCHEDULING_INTERVAL_MINUTES=15
MAX_CLEANING_STAFF=50
AVG_CLEANING_TIME_MINUTES=25
BUFFER_TIME_MINUTES=5

# Predictive Model Configuration
PREDICTION_HORIZON_HOURS=24
OCCUPANCY_FORECAST_DAYS=7
MAINTENANCE_THRESHOLD_DAYS=7

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080