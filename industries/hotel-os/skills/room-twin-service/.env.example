# Service Configuration
SERVICE_NAME=room-twin-service
SERVICE_PORT=8444
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/room_twin
MONGODB_USER=
MONGODB_PASSWORD=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URI=amqp://localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# TwinOS Configuration
TWINOS_API_URL=http://localhost:8080
TWINOS_API_KEY=

# Predictive Housekeeping Integration (8446)
PREDICTIVE_HK_URL=http://localhost:8446
PREDICTIVE_HK_API_KEY=

# Invisible Hotel Integration
INVISIBLE_HOTEL_URL=http://localhost:8443
INVISIBLE_HOTEL_API_KEY=

# Smart Minibar Integration (8445)
SMART_MINIBAR_URL=http://localhost:8445
SMART_MINIBAR_API_KEY=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
