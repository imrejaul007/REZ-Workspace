# Service Configuration
SERVICE_NAME=property-twin-service
SERVICE_PORT=8445
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/property_twin
MONGODB_USER=
MONGODB_PASSWORD=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URI=amqp://localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# TwinOS Configuration
TWINOS_API_URL=http://localhost:8080
TWINOS_API_KEY=

# REZ POS Integration (8449)
REZ_POS_URL=http://localhost:8449
REZ_POS_API_KEY=

# Upsell Engine Integration (8448)
UPSELL_ENGINE_URL=http://localhost:8448
UPSELL_ENGINE_API_KEY=

# AI Concierge Integration (8444)
AI_CONCIERGE_URL=http://localhost:8444
AI_CONCIERGE_API_KEY=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
