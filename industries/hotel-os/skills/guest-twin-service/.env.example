# Service Configuration
SERVICE_NAME=guest-twin-service
SERVICE_PORT=8443
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/guest_twin
MONGODB_USER=
MONGODB_PASSWORD=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ Configuration
RABBITMQ_URI=amqp://localhost:5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# TwinOS Configuration
TWINOS_API_URL=http://localhost:8080
TWINOS_API_KEY=

# Guest Memory Integration (8447)
GUEST_MEMORY_URL=http://localhost:8447
GUEST_MEMORY_API_KEY=

# REZ Loyalty Integration (8450)
REZ_LOYALTY_URL=http://localhost:8450
REZ_LOYALTY_API_KEY=

# BrandPulse Integration (8451)
BRANDPULSE_URL=http://localhost:8451
BRANDPULSE_API_KEY=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
