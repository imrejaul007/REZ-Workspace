# Hojai Telecom Bridge

# Active Provider (twilio, exotel, knowlarity, ozonetel)
TELECOM_PROVIDER=twilio

# Twilio (for international)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Exotel (for India)
EXOTEL_API_KEY=your_api_key
EXOTEL_API_TOKEN=your_api_token
EXOTEL_SUBDOMAIN=your_subdomain
EXOTEL_CALLER_ID=022XXXXXXXX
EXOTEL_SMS_SENDER=022XXXXXXXX

# Knowlarity (for India)
KNOWLARITY_API_KEY=your_api_key
KNOWLARITY_CALLER_ID=022XXXXXXXX

# Server
PORT=4860
