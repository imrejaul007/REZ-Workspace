# BrandPulse Production Environment
# DO NOT commit this file with real secrets

# Service
PORT=4770
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb://admin:${MONGO_PASSWORD}@mongodb:27017/brandpulse?authSource=admin

# Redis
REDIS_URL=redis://redis:6379

# OpenAI (for advanced sentiment analysis)
OPENAI_API_KEY=${OPENAI_API_KEY}

# Authentication
API_KEY=${BRANDPULSE_API_KEY}
INTERNAL_SERVICE_TOKEN=${INTERNAL_SERVICE_TOKEN}

# RTNM Integration
RTNM_GATEWAY_URL=http://rez-unified-hub:4600
REZ_BRIDGE_ENABLED=true

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
