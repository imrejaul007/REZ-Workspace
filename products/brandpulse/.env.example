# HOJAI BrandPulse Environment Configuration
# Copy to .env and configure for your environment

# Service
PORT=4770
NODE_ENV=development

# MongoDB (for brand and review data)
MONGODB_URI=mongodb://localhost:27017/brandpulse

# Redis (for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# PostgreSQL (for analytics - optional)
POSTGRES_URL=postgresql://user:pass@localhost:5432/brandpulse

# OpenAI (for advanced sentiment analysis)
OPENAI_API_KEY=sk-your-openai-key

# Authentication
API_KEY=your-brandpulse-api-key
INTERNAL_SERVICE_TOKEN=rez-internal-service-token

# RTNM Integration
RTNM_GATEWAY_URL=http://localhost:4600
REZ_BRIDGE_ENABLED=true

# Rate Limiting
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000

# Logging
LOG_LEVEL=info
