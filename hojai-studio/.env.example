PORT=4850
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hojai_studio

# Redis
REDIS_URL=redis://localhost:6379

# Hojai Services
HOJAI_AGENTS_URL=http://localhost:4550
HOJAI_COMMUNICATIONS_URL=http://localhost:4570
REZ_WHATSAPP_URL=http://localhost:4202

# Auth
INTERNAL_SERVICE_TOKEN=your-internal-token
JWT_SECRET=your-jwt-secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Limits
MAX_BOT_NODES=500
MAX_BOT_FLOWS=50
