{
  "name": "airzy",
  "version": "1.0.0",
  "private": true,
  "description": "Airzy - Premium Airport & Frequent Traveler Ecosystem",
  "workspaces": [
    "airzy-api-gateway",
    "airzy-flight-service",
    "airzy-lounge-service",
    "airzy-itinerary-service",
    "airzy-wallet-extension",
    "airzy-ai-brain",
    "airzy-corp-service",
    "airzy-hotel-extension",
    "airzy-transfer-extension",
    "airzy-dooh-extension",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:services\"",
    "dev:gateway": "cd airzy-api-gateway && npm run dev",
    "dev:services": "concurrently -n flight,lounge,itinerary,wallet,ai,corp,hotel,transfer,dooh -c blue,green,yellow,cyan,magenta,red,white,gray \"npm run dev:flight\" \"npm run dev:lounge\" \"npm run dev:itinerary\" \"npm run dev:wallet\" \"npm run dev:ai\" \"npm run dev:corp\" \"npm run dev:hotel\" \"npm run dev:transfer\" \"npm run dev:dooh\"",
    "dev:flight": "cd airzy-flight-service && npm run dev",
    "dev:lounge": "cd airzy-lounge-service && npm run dev",
    "dev:itinerary": "cd airzy-itinerary-service && npm run dev",
    "dev:wallet": "cd airzy-wallet-extension && npm run dev",
    "dev:ai": "cd airzy-ai-brain && npm run dev",
    "dev:corp": "cd airzy-corp-service && npm run dev",
    "dev:hotel": "cd airzy-hotel-extension && npm run dev",
    "dev:transfer": "cd airzy-transfer-extension && npm run dev",
    "dev:dooh": "cd airzy-dooh-extension && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:mobile": "cd apps/mobile && npm start",
    "build": "npm run build:services && npm run build:web",
    "build:services": "concurrently \"npm run build:gateway\" \"npm run build:services:all\"",
    "build:gateway": "cd airzy-api-gateway && npm run build",
    "build:services:all": "concurrently -n flight,lounge,itinerary,wallet,ai,corp,hotel,transfer,dooh \"npm run build:flight\" \"npm run build:lounge\" \"npm run build:itinerary\" \"npm run build:wallet\" \"npm run build:ai\" \"npm run build:corp\" \"npm run build:hotel\" \"npm run build:transfer\" \"npm run build:dooh\"",
    "build:flight": "cd airzy-flight-service && npm run build",
    "build:lounge": "cd airzy-lounge-service && npm run build",
    "build:itinerary": "cd airzy-itinerary-service && npm run build",
    "build:wallet": "cd airzy-wallet-extension && npm run build",
    "build:ai": "cd airzy-ai-brain && npm run build",
    "build:corp": "cd airzy-corp-service && npm run build",
    "build:hotel": "cd airzy-hotel-extension && npm run build",
    "build:transfer": "cd airzy-transfer-extension && npm run build",
    "build:dooh": "cd airzy-dooh-extension && npm run build",
    "build:web": "cd apps/web && npm run build",
    "build:mobile": "cd apps/mobile && npx expo export --platform all",
    "test": "concurrently \"npm run test:services\"",
    "test:services": "cd airzy-wallet-extension && npm test",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "discover": "node scripts/service-discovery.js",
    "clean": "rm -rf **/dist **/node_modules .next"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "airzy",
    "travel",
    "airport",
    "lounge",
    "flights",
    "hotels",
    "rewards"
  ],
  "author": "RTNM Group",
  "license": "proprietary"
}
