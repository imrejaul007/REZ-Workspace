{
  "name": "rez-ride",
  "version": "1.0.0",
  "description": "India's first commission-free ride-hailing platform",
  "private": true,
  "workspaces": [
    "src/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:services\" \"npm run dev:apps\"",
    "dev:services": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:apps": "cd apps/user-app && npm run dev",
    "build": "npm run build:services && npm run build:apps",
    "build:services": "tsc --build",
    "build:apps": "echo 'Building apps via workspaces...'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.23",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^11.1.23",
    "@nestjs/platform-socket.io": "^11.1.23",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/websockets": "^11.1.23",
    "amqplib": "^0.10.3",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "date-fns": "^3.2.0",
    "eas-cli": "3.3.1",
    "expo": "56.0.3",
    "expo-dev-client": "^56.0.15",
    "expo-notifications": "56.0.12",
    "express-rate-limit": "^7.1.0",
    "geo-tz": "^8.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.1.0",
    "node-geocoder": "^1.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "sentry-expo": "5.0.3",
    "socket.io": "^4.6.0",
    "twilio": "^4.20.0",
    "uuid": "^14.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.23",
    "@types/amqplib": "^0.10.4",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "concurrently": "^8.2.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
