# KHAIRMOVE Root Environment Variables
# Copy to .env and customize

# ============================================
# INFRASTRUCTURE
# ============================================
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017

# Redis
REDIS_URL=redis://localhost:6379

# ============================================
# REZ INTELLIGENCE SERVICES
# ============================================
REZ_INTENT_URL=http://localhost:4018
REZ_SIGNAL_URL=http://localhost:4142
REZ_FRAUD_URL=http://localhost:3007
REZ_PREDICTIVE_URL=http://localhost:4123
REZ_LOCATION_URL=http://localhost:4040
REZ_MEMORY_URL=http://localhost:4201

# ============================================
# RABTUL SERVICES
# ============================================
AUTH_SERVICE_URL=http://localhost:4002
WALLET_SERVICE_URL=http://localhost:4004
PAYMENT_SERVICE_URL=http://localhost:4001
NOTIFICATION_SERVICE_URL=http://localhost:4011

# ============================================
# SECURITY
# ============================================
INTERNAL_SERVICE_TOKEN=your-secure-internal-token-change-in-production
REZ_INTELLIGENCE_API_KEY=your-rez-api-key

# ============================================
# CARRIER API KEYS
# ============================================
DELHIVERY_API_KEY=your-delhivery-api-key
BLUEDART_API_KEY=your-bluedart-api-key
DTDC_API_KEY=your-dtdc-api-key
DTDC_CUSTOMER_ID=your-dtdc-customer-id
FEDEX_CLIENT_ID=your-fedex-client-id
FEDEX_CLIENT_SECRET=your-fedex-client-secret
DHL_API_KEY=your-dhl-api-key
