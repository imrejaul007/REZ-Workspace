# ================================================
# REZ-Inventory-Engine Environment Variables
# ================================================

# ================================================
# APPLICATION SETTINGS
# ================================================

# Service Identity
SERVICE_NAME=rez-inventory-engine
SERVICE_VERSION=1.0.0
NODE_ENV=development
PORT=4010

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=/app/logs

# Feature Flags
FEATURE_METRICS_ENABLED=true
FEATURE_TRACING_ENABLED=true
FEATURE_DEBUG_MODE=false

# ================================================
# DATABASE CONFIGURATION
# ================================================

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez_inventory
MONGODB_DATABASE=rez_inventory
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_AUTH_SOURCE=admin
MONGODB_REPLICA_SET=
MONGODB_DIRECT_CONNECTION=true

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=rez:inventory:

# ================================================
# AUTHENTICATION & SECURITY
# ================================================

# JWT Configuration
JWT_SECRET=CHANGE_ME_generate_strong_secret_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256

# Internal API Authentication
INTERNAL_API_KEY=CHANGE_ME_generate_strong_api_key_here
API_KEY_HEADER=X-API-Key

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.rezmerchant.com,https://admin.rezmerchant.com
CORS_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization,X-API-Key,X-Request-ID

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Security Headers
HELMET_ENABLED=true
HELMET_CSP=true
HELMET_HSTS=true

# ================================================
# MONITORING & OBSERVABILITY
# ================================================

# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PATH=/metrics

# Sentry Error Tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Health Checks
HEALTH_CHECK_INTERVAL=30s

# ================================================
# EXTERNAL SERVICES
# ================================================

# RABTUL Services
RABTUL_AUTH_URL=http://localhost:4002
RABTUL_PAYMENT_URL=http://localhost:4001
RABTUL_WALLET_URL=http://localhost:4004
RABTUL_NOTIFICATION_URL=http://localhost:4005

# Slack Notifications
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts
SLACK_NOTIFY_ON_ERROR=true

# Email (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@rezmerchant.com

# ================================================
# CLOUD SERVICES
# ================================================

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
AWS_S3_BUCKET=rez-merchant-uploads

# Cloudinary (image processing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ================================================
# BUSINESS CONFIGURATION
# ================================================

# Multi-tenancy
MULTI_TENANT_MODE=true
DEFAULT_TENANT_ID=default

# Cache TTL (in seconds)
CACHE_TTL_SHORT=60
CACHE_TTL_MEDIUM=300
CACHE_TTL_LONG=3600

# Queue Configuration
QUEUE_CONCURRENCY=5
JOB_RETRY_ATTEMPTS=3
JOB_RETRY_DELAY=5000

# ================================================
# DEVELOPMENT SETTINGS
# ================================================

# Debug
DEBUG_MODE=false
INSPECT_PORT=9229

# Test Database
TEST_MONGODB_URI=mongodb://localhost:27017/rez_inventory_test
TEST_REDIS_DB=1

# ================================================
# DEPLOYMENT SETTINGS
# ================================================

# Docker
DOCKER_NETWORK=rez-network

# Kubernetes
K8S_NAMESPACE=rez-merchant
K8S_INGRESS_CLASS=nginx

# Container Registry
IMAGE_REGISTRY=ghcr.io/imrejaul007