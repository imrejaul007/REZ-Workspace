# =============================================================================
# REZ Events OS - Environment Variables
# =============================================================================

NODE_ENV=development
SERVICE_NAME=rez-events

# Ports (Events OS: 4750-4799)
PORT=4751

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-events

# Redis
REDIS_URL=redis://localhost:6379

# REZ Core Services
REZ_AUTH_URL=http://localhost:4002
REZ_PAYMENT_URL=http://localhost:4001

# Events Services (Internal)
REZ_EVENTS_ANALYTICS_URL=http://localhost:4752

# Security
JWT_SECRET=your-jwt-secret
INTERNAL_SERVICE_TOKEN=your-internal-token

# CORS
CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=info