# =============================================================================
# REZ Fitness OS - Environment Variables
# =============================================================================

NODE_ENV=development
SERVICE_NAME=rez-fitness

# Ports (Fitness OS: 4550-4599)
PORT=4551

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-fitness

# Redis
REDIS_URL=redis://localhost:6379

# REZ Core Services
REZ_AUTH_URL=http://localhost:4002
REZ_PAYMENT_URL=http://localhost:4001

# Fitness Services (Internal)
REZ_GYM_URL=http://localhost:4552

# Security
JWT_SECRET=your-jwt-secret
INTERNAL_SERVICE_TOKEN=your-internal-token

# CORS
CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=info