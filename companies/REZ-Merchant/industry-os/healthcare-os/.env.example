# =============================================================================
# REZ Healthcare OS - Environment Variables
# =============================================================================

NODE_ENV=development
SERVICE_NAME=rez-healthcare

# Ports (Healthcare OS: 4500-4549)
PORT=4501

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-healthcare

# Redis
REDIS_URL=redis://localhost:6379

# REZ Core Services
REZ_AUTH_URL=http://localhost:4002
REZ_PAYMENT_URL=http://localhost:4001

# Healthcare Services (Internal)
REZ_PHARMACY_URL=http://localhost:4502
REZ_PRESCRIPTION_URL=http://localhost:4503

# Security
JWT_SECRET=your-jwt-secret
INTERNAL_SERVICE_TOKEN=your-internal-token

# HIPAA Compliance
ENABLE_AUDIT_LOG=true
ENABLE_DATA_ENCRYPTION=true

# CORS
CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=info