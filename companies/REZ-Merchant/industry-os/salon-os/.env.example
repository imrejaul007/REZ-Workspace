# =============================================================================
# REZ Salon OS - Environment Variables
# =============================================================================

NODE_ENV=development
SERVICE_NAME=rez-salon

# Ports (Salon OS: 4900-4949)
PORT=4901

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-salon

# Redis
REDIS_URL=redis://localhost:6379

# REZ Core Services
REZ_AUTH_URL=http://localhost:4002
REZ_PAYMENT_URL=http://localhost:4001

# Salon Services (Internal)
REZ_SALON_POS_URL=http://localhost:4902
REZ_SALON_CRM_URL=http://localhost:4903
REZ_SALON_MEMBERSHIP_URL=http://localhost:4904

# WhatsApp (if enabled)
WHATSAPP_API_URL=http://localhost:3005

# Security
JWT_SECRET=your-jwt-secret
INTERNAL_SERVICE_TOKEN=your-internal-token

# CORS
CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=info