# =============================================================================
# REZ Restaurant OS - Environment Variables
# =============================================================================

NODE_ENV=development
SERVICE_NAME=rez-restaurant

# Ports (Restaurant OS: 4100-4149)
PORT=4101

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-restaurant

# Redis
REDIS_URL=redis://localhost:6379

# REZ Core Services
REZ_AUTH_URL=http://localhost:4002
REZ_PAYMENT_URL=http://localhost:4001
REZ_WALLET_URL=http://localhost:4004
REZ_NOTIFICATION_URL=http://localhost:4005

# Restaurant Services (Internal)
REZ_POS_URL=http://localhost:4102
REZ_KDS_URL=http://localhost:4103
REZ_RESERVATIONS_URL=http://localhost:4104
REZ_ANALYTICS_URL=http://localhost:4106

# Security
JWT_SECRET=your-jwt-secret
INTERNAL_SERVICE_TOKEN=your-internal-token

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Logging
LOG_LEVEL=info