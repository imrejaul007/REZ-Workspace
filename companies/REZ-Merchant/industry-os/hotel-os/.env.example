# =============================================================================
# REZ Hotel OS - Environment Variables Template
# =============================================================================
# Copy this file to .env in each service and update values

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
NODE_ENV=development
SERVICE_NAME=rez-hotel-service

# =============================================================================
# PORTS (Hotel OS Range: 4800-4899)
# =============================================================================
PORT=4801

# =============================================================================
# MONGODB
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/rez-hotel
MONGODB_USER=
MONGODB_PASSWORD=

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# RABTUL SERVICES (Auth/Wallet/Payment)
# =============================================================================
REZ_AUTH_URL=http://localhost:4002
REZ_PAYMENT_URL=http://localhost:4001
REZ_WALLET_URL=http://localhost:4004
REZ_NOTIFICATION_URL=http://localhost:4005
REZ_CATALOG_URL=http://localhost:4008
REZ_ORDERS_URL=http://localhost:4009

# =============================================================================
# HOJAI AI SERVICES
# =============================================================================
HOJAI_BRAIN_URL=http://localhost:4630
HOJAI_MEMORY_URL=http://localhost:4540
HOJAI_KNOWLEDGE_URL=http://localhost:4300
HOJAI_AGENTS_URL=http://localhost:4541

# =============================================================================
# HOTEL OS SERVICES (Internal)
# =============================================================================
REZ_BOOKING_URL=http://localhost:4801
REZ_STAYBOT_URL=http://localhost:4840
REZ_HOUSEKEEPING_URL=http://localhost:4830
REZ_PAYMENT_URL=http://localhost:4870
REZ_CHANNEL_MANAGER_URL=http://localhost:4860
REZ_ANALYTICS_URL=http://localhost:4804

# =============================================================================
# SECURITY
# =============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
INTERNAL_SERVICE_TOKEN=your-internal-service-token-change-in-production
ENCRYPTION_KEY=your-32-char-encryption-key

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# SENTRY (Optional - Error Tracking)
# =============================================================================
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info

# =============================================================================
# HOTEL SPECIFIC
# =============================================================================
DEFAULT_CURRENCY=INR
DEFAULT_TIMEZONE=Asia/Kolkata
CHECK_IN_TIME=14:00
CHECK_OUT_TIME=12:00
