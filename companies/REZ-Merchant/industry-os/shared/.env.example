# REZ Merchant Admin Portals - Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4005
API_URL=http://localhost:4005

# Authentication
AUTH_TOKEN_KEY=rez_auth_token
AUTH_REFRESH_TOKEN_KEY=rez_refresh_token

# REZ Ecosystem Services
REZ_AUTH_URL=http://localhost:4002
REZ_WALLET_URL=http://localhost:4004
REZ_PAYMENT_URL=http://localhost:4003

# HOJAI AI Integration
NEXT_PUBLIC_HOJAI_URL=http://localhost:4800
HOJAI_API_KEY=your_hojai_api_key

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_DARK_MODE=false
NEXT_PUBLIC_ENABLE_NOTIFICATIONS=true

# Database (for SSR if needed)
DATABASE_URL=postgresql://user:pass@localhost:5432/rez_merchant

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
NEXT_PUBLIC_SENTRY_DSN=

# Environment
NODE_ENV=development
