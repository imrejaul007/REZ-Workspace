# =============================================================================
# REZ Retail OS - Environment Variables
# =============================================================================

NODE_ENV=development
SERVICE_NAME=rez-retail

# Ports (Retail OS: 4600-4649)
PORT=4601

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-retail

# Redis
REDIS_URL=redis://localhost:6379

# REZ Core Services
REZ_AUTH_URL=http://localhost:4002
REZ_PAYMENT_URL=http://localhost:4001

# Retail Services (Internal)
REZ_RETAIL_POS_URL=http://localhost:4602
REZ_RETAIL_INVENTORY_URL=http://localhost:4603
REZ_RETAIL_ANALYTICS_URL=http://localhost:4604

# Security
JWT_SECRET=your-jwt-secret
INTERNAL_SERVICE_TOKEN=your-internal-token

# CORS
CORS_ORIGINS=http://localhost:3000

LOG_LEVEL=info