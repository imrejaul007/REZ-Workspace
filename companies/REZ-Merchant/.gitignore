# SECURITY FIX (MA-BACK-AUDIT-006): Comprehensive .gitignore to prevent committing secrets.
# Environment files
.env
.env.*
.env.bak*
!.env.example

# Credentials and secrets
*.pem
*.key
*.crt
credentials.json
secrets.json
service-account.json

# Local development
*.local
*.dev

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
.next/
out/
dist/
build/

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
.nyc_output/

# IDE
.idea/
.vscode/
*.swp
*.swo
*.sublime-workspace
*.sublime-project

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Claude Code
.claude/
.claude-flow/

# Temporary files
*.tmp
*.temp
*.bak
node_modules
