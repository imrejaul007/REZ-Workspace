# ================================================
# Atlas Qualification Agent Environment Variables
# ================================================

# Service Identity
SERVICE_NAME=atlas-qualification-agent
SERVICE_VERSION=2.0.0
NODE_ENV=development
PORT=5175

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=/app/logs

# MongoDB
MONGODB_URI=mongodb://localhost:27017/atlas-qualification-agent
MONGODB_DATABASE=atlas-qualification-agent

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Security
HELMET_ENABLED=true
JWT_SECRET=change-this-to-a-secure-random-string
