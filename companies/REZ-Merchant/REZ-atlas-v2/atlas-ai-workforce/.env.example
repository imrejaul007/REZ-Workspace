# Atlas AI Workforce Configuration
PORT=5190
NODE_ENV=production
SERVICE_NAME=atlas-ai-workforce

# MongoDB
MONGODB_URI=mongodb://localhost:27017/atlas-ai-workforce

# Redis
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=CHANGE_ME_generate_strong_secret_here

# Logging
LOG_LEVEL=info

# Nested Service URLs (for Kubernetes internal DNS)
SDR_AGENT_URL=http://atlas-sdr-agent:5174
QUALIFICATION_AGENT_URL=http://atlas-qualification-agent:5175
MEETING_AGENT_URL=http://atlas-meeting-agent:5176

# Service Specific
ATLAS_AI_WORKFORCE_API_KEY=your_api_key_here
