# ================================================
# Atlas CRM Core Environment Variables
# ================================================

SERVICE_NAME=atlas-crm-core
SERVICE_VERSION=2.0.0
NODE_ENV=development
PORT=5183

LOG_LEVEL=info
LOG_DIR=/app/logs

MONGODB_URI=mongodb://localhost:27017/atlas-crm-core
MONGODB_DATABASE=atlas-crm-core

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

HELMET_ENABLED=true
JWT_SECRET=change-this-to-a-secure-random-string