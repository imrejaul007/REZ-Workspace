# ================================================
# REZ Atlas Signals - Environment Configuration
# ================================================

# Service Configuration
PORT=5155
NODE_ENV=production
SERVICE_NAME=REZ-atlas-signals
SERVICE_VERSION=1.0.0

# Database
MONGODB_URI=mongodb://localhost:27017/REZ-atlas-signals
MONGODB_DATABASE=REZ-atlas-signals

# Cache
REDIS_URL=redis://localhost:6379
REDIS_DATABASE=0

# Authentication
JWT_SECRET=CHANGE_ME_generate_strong_secret_here_min_32_chars
JWT_EXPIRES_IN=24h

# Logging
LOG_LEVEL=info
LOG_DIR=/app/logs

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://app.rezmerchant.com,https://admin.rezmerchant.com
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Web Intelligence Integration
WEB_INTELLIGENCE_URL=http://localhost:4595

# RABTUL Services Integration
RABTUL_AUTH_URL=http://localhost:4002
RABTUL_PAYMENT_URL=http://localhost:4001
RABTUL_WALLET_URL=http://localhost:4004
RABTUL_NOTIFICATION_URL=http://localhost:4005

# Internal API
INTERNAL_API_KEY=your_internal_api_key_here

# External Services
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# Feature Flags
FEATURE_METRICS_ENABLED=true
FEATURE_TRACING_ENABLED=true