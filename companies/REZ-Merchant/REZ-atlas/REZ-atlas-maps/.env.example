# REZ Atlas Maps Environment Variables

# Service
SERVICE_NAME=REZ-atlas-maps
SERVICE_VERSION=1.0.0
NODE_ENV=development
PORT=5152

# Logging
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-atlas-maps
MONGODB_DATABASE=rez-atlas-maps

# Redis
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Security
JWT_SECRET=change-this-to-a-secure-random-string
INTERNAL_API_KEY=change-this-to-a-secure-api-key

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Feature Flags
FEATURE_METRICS_ENABLED=true
FEATURE_TRACING_ENABLED=true

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# RABTUL Services (legacy)
RABTUL_AUTH_URL=http://localhost:4002
RABTUL_PAYMENT_URL=http://localhost:4001
RABTUL_WALLET_URL=http://localhost:4004
RABTUL_NOTIFICATION_URL=http://localhost:4005