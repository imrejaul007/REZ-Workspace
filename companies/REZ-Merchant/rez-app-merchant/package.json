    "@babel/plugin-transform-react-jsx-development": "^7.27.1",
    "@babel/plugin-transform-react-pure-annotations": "^7.27.1",
    "@types/crypto-js": "^4.2.2",
    "@types/detox": "^18.1.0",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.3.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.5.1",
    "crypto-js": "^4.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "hermes-compiler": "^250829098.0.2",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.5",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "tar": "^7.5.11",
    "typescript": "~5.3.0",
    "util": "^0.12.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "lint-staged": {
    "app/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "app/**/*.tsx": [
      "eslint --fix",
      "prettier --write"
    ]
  }
