    "react-dom": "18.3.1",
    "react-hook-form": "^7.52.0",
    "react-native": "0.76.9",
    "react-native-animatable": "^1.4.0",
    "react-native-draggable-flatlist": "^4.0.1",
    "react-native-gesture-handler": "~2.20.0",
