{
  "name": "merchant-app",
  "version": "1.0.0",
  "main": "index.ts",
  "overrides": {
    "@xmldom/xmldom": ">=0.9.0",
    "victory-native": "36.9.2",
    "@shopify/react-native-skia": "1.3.0",
    "postcss": ">=8.5.10",
    "undici": ">=7.0.0",
    "socket.io-parser": ">=4.2.6",
    "minimatch": ">=3.1.4",
    "picomatch": ">=2.3.1",
    "node-forge": ">=1.3.4"
  },
  "scripts": {
    "start": "expo start --port 8082",
    "start:clear": "node scripts/clear-cache.js && expo start --port 8082",
    "clear-cache": "node scripts/clear-cache.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8082",
    "build": "expo export",
    "build:web": "EXPO_ROUTER_APP_ROOT=./app expo export --platform web",
    "eas:configure": "eas build:configure",
    "build:dev:ios": "eas build --platform ios --profile development",
    "build:dev:android": "eas build --platform android --profile development",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:prod:ios": "eas build --platform ios --profile production",
    "build:prod:android": "eas build --platform android --profile production",
    "build:prod:all": "eas build --platform all --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "prepare": "husky",
    "test": "jest --no-coverage",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch --no-coverage",
    "format": "prettier --write 'app/**/*.ts' 'app/**/*.tsx'"
  },
  "dependencies": {
    "@expo/cli": "~0.24.24",
    "@expo/config-plugins": "~10.0.0",
    "@expo/metro-runtime": "~0.1.0",
