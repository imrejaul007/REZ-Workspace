    "@rez/brand-tokens": "file:../packages/rez-brand-tokens",
    "@rez/loyalty-client": "file:../packages/rez-loyalty-client",
    "@rez/shared": "file:./packages/rez-shared",
    "@rez/shared-types": "file:../packages/shared-types",
    "@sentry/react-native": "~6.10.0",
    "@shopify/flash-list": "1.7.3",
    "@tanstack/react-query": "^5.45.0",
    "@types/react": "~18.3.0",
    "axios": "^1.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "compression": "^1.8.1",
    "date-fns": "^3.6.0",
    "expo": "~53.0.27",
    "expo-av": "~15.0.2",
    "expo-camera": "~16.0.0",
