    "expo-file-system": "~18.0.0",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.0",
    "expo-image": "~2.0.0",
    "expo-image-picker": "~16.0.0",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~7.1.7",
    "expo-local-authentication": "~15.0.2",
    "expo-location": "~18.0.0",
    "expo-media-library": "~17.0.0",
    "expo-notifications": "^0.31.5",
    "expo-print": "~14.0.0",
