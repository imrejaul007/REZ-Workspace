{
  "name": "rez-barcode-scanner-ui",
  "version": "1.0.0",
  "description": "Barcode Scanner UI Components for ReZ App",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "html5-qrcode": "^2.3.8",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "barcode",
    "scanner",
    "react",
    "ui",
    "components"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ]
}