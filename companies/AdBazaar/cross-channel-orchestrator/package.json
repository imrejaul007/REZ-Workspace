{
  "name": "@rez/cross-channel-orchestrator",
  "version": "1.0.0",
  "description": "Unified DSP for cross-channel campaign orchestration - WhatsApp, SMS, Email, Push",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:debug": "node --inspect=0.0.0.0:9229 --require ts-node/register src/index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t rez-cross-channel-orchestrator .",
    "docker:build:prod": "docker build -t rez-cross-channel-orchestrator:prod --target production .",
    "docker:run": "docker run -p 4812:4812 --env-file .env.local rez-cross-channel-orchestrator",
    "health": "curl -s http://localhost:4812/health | jq",
    "seed": "node dist/jobs/seed.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "mongoose": "^8.0.0",
    "ioredis": "^5.3.2",
    "zod": "^3.22.4",
    "uuid": "^9.0.1",
    "axios": "^1.6.0",
    "jsonwebtoken": "^9.0.2",
    "express-rate-limit": "^7.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "bullmq": "^5.1.0",
    "dotenv": "^16.4.5",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^9.0.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "dsp",
    "cross-channel",
    "whatsapp",
    "sms",
    "email",
    "push-notifications",
    "campaign",
    "orchestration",
    "marketing"
  ],
  "author": "REZ Media",
  "license": "MIT"
}
