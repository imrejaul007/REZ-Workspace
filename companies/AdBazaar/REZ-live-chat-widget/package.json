{
  "name": "@rezmedia/live-chat-widget",
  "version": "1.0.0",
  "description": "REZ Live Chat Widget SDK - Embeddable live chat widget for websites",
  "main": "dist/widget.cjs.js",
  "module": "dist/widget.esm.js",
  "browser": "dist/widget.umd.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/widget.esm.js",
      "require": "./dist/widget.cjs.js",
      "browser": "./dist/widget.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/widget.ts src/types/index.ts src/services/api.ts src/components/*.tsx --format cjs,esm,umd --dts --external react,preact",
    "dev": "tsup src/widget.ts src/types/index.ts src/services/api.ts src/components/*.tsx --format cjs,esm,umd --dts --external react,preact --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest",
    "test:run": "vitest run",
    "prepare": "npm run build"
  },
  "keywords": [
    "chat",
    "widget",
    "live-chat",
    "customer-support",
    "messaging",
    "embeddable"
  ],
  "author": "REZ Media",
  "license": "MIT",
  "peerDependencies": {
    "preact": "^10.0.0 || ^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "preact": "^10.19.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "bundler": {
    "entry": "src/widget.ts",
    "formats": [
      "cjs",
      "esm",
      "umd"
    ]
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}