{
  "name": "@rez/marketing",
  "version": "1.0.0",
  "description": "REZ Ads Manager — audience targeting, cross-channel campaigns, keyword ads",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "format": "prettier --write src/**/*.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@rez/shared": "file:../rez-shared",
    "@sentry/node": "^8.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.23",
    "axios": "^1.7.2",
    "bullmq": "^5.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "mongoose": "^8.23.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.15",
    "prom-client": "^15.1.0",
    "twilio": "^5.2.2",
    "typescript": "^5.9.3",
    "uuid": "^14.0.0",
    "qrcode": "^1.5.3",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand",
    "test:jest": "jest --runInBand"
  }
}
