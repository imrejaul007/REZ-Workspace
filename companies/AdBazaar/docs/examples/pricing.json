    {
      "title": "Liquidation Pricing",
      "request": {
        "method": "POST",
        "path": "/v1/price/liquidation",
        "headers": {
          "Authorization": "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
          "Content-Type": "application/json"
        },
        "body": {
          "originalPrice": 5000,
          "hoursUntilSlot": 4,
          "percentSold": 35
        }
      },
      "response": {
        "status": 200,
        "body": {
          "success": true,
          "data": {
            "originalPrice": 5000,
            "liquidationPrice": 3500,
            "discountPercent": "30.0",
            "reason": "Below target sell-through"
          }
        }
      }
