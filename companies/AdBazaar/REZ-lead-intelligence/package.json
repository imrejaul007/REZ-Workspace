    "axios": "^1.6.7",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "mongoose": "^8.23.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "redis": "^4.6.13",
    "swagger-jsdoc": "^6.2.8",
