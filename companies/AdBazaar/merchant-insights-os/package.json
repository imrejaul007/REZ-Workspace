{
  "name": "merchant-insights-os",
  "version": "1.0.0",
  "description": "Merchant Intelligence OS - tells merchants what to do, not just run ads",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.2.0",
    "winston": "^3.11.0",
    "prom-client": "^15.1.0",
    "zod": "^3.22.4",
    "axios": "^1.6.7",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "uuid": "^9.0.1",
    "date-fns": "^3.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.11.19",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
