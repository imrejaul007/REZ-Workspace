{
  "name": "@rez-media/communications-platform",
  "version": "1.0.0",
  "description": "Multi-channel communications platform for REZ (Email, SMS, WhatsApp, Push)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.0",
    "twilio": "^4.23.0",
    "whatsapp-web.js": "^1.23.0",
    "firebase-admin": "^12.0.0",
    "firebase": "^10.8.0",
    "handlebars": "^4.7.8",
    "zod": "^3.22.4",
    "ioredis": "^5.3.2",
    "winston": "^3.11.0",
    "p-limit": "^3.1.0",
    "joi": "^17.12.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "communications",
    "email",
    "sms",
    "whatsapp",
    "push-notifications",
    "multi-channel",
    "transactional"
  ],
  "author": "REZ Media",
  "license": "MIT"
}
