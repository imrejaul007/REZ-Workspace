{
  "name": "apartment-targeting-service",
  "version": "1.0.0",
  "description": "Hyperlocal apartment/community targeting service for AdBazaar",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.2.0",
    "redis": "^4.6.12",
    "zod": "^3.22.4",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "prom-client": "^15.1.0",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1",
    "axios": "^1.6.7",
    "geo-tz": "^0.0.2",
    "haversine-distance": "^1.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.11.19",
    "@types/jest": "^29.5.12",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/supertest": "^6.0.2",
    "supertest": "^6.3.4",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
