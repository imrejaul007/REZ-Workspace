# Hojai AI - Environment Configuration
# Version: 1.0 | Date: May 29, 2026

# ============================================
# GENERAL
# ============================================
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# PORTS
# ============================================
PORT=4500

# ============================================
# DATABASE (MongoDB)
# ============================================
MONGODB_URI=mongodb://localhost:27017/hojai
MONGODB_USER=
MONGODB_PASSWORD=

# ============================================
# CACHE (Redis)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================
# TENANT CONFIGURATION
# ============================================
DEFAULT_TENANT_LIMIT=1000
MAX_TENANTS=10000

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# EXTERNAL SERVICES
# ============================================

# RABTUL Services (unchanged)
AUTH_SERVICE_URL=http://localhost:4002
PAYMENT_SERVICE_URL=http://localhost:4001
WALLET_SERVICE_URL=http://localhost:4004
INTERNAL_SERVICE_TOKEN=change-me-in-production

# ============================================
# INDUSTRY BRAIN
# ============================================
MIN_TENANTS_FOR_AGGREGATION=3
MIN_EVENTS_FOR_AGGREGATION=100
MAX_SINGLE_TENANT_CONTRIBUTION=0.5

# ============================================
# SECURITY
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ============================================
# LOGGING
# ============================================
LOG_FORMAT=json
LOG_DESTINATION=stdout
