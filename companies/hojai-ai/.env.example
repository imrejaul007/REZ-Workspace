# =============================================================================
# HOJAI AI - Environment Variables Template
# =============================================================================

# Copy this file to .env and fill in the values

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
PORT=3000
NODE_ENV=production

# =============================================================================
# RABTUL CORE SERVICES (REQUIRED)
# Core authentication, payment, wallet, and notification services
# =============================================================================
RABTUL_AUTH_URL=http://localhost:4002
RABTUL_PAYMENT_URL=http://localhost:4001
RABTUL_WALLET_URL=http://localhost:4004
RABTUL_NOTIFICATION_URL=http://localhost:4005

# =============================================================================
# REZ IDENTITY HUB (REQUIRED)
# 25-source pre-call research and user profile management
# =============================================================================
REZ_IDENTITY_URL=http://localhost:6000

# =============================================================================
# HOJAI SKILLNET (REQUIRED)
# AI skills and domain expertise services
# =============================================================================
SKILLNET_URL=http://localhost:5130
INTELLIGENCE_URL=http://localhost:5130
RUNTIME_URL=http://localhost:5120

# =============================================================================
# HOJAI SERVICES
# =============================================================================
BRANDPULSE_URL=http://localhost:4770
GENIE_VOICE_URL=http://localhost:4760
GENIE_MEMORY_SERVICE_URL=http://localhost:4520

# =============================================================================
# INDUSTRY AI (Optional)
# 28 industry verticals - configure as needed
# =============================================================================
INDUSTRY_HEALTHCARE_URL=http://localhost:3001
INDUSTRY_LEGAL_URL=http://localhost:3002
INDUSTRY_FINANCE_URL=http://localhost:3003
INDUSTRY_RE_URL=http://localhost:3004
INDUSTRY_HOSPITALITY_URL=http://localhost:3005
INDUSTRY_RESTAURANT_URL=http://localhost:3006
INDUSTRY_FLEET_URL=http://localhost:3007
INDUSTRY_EDUCATION_URL=http://localhost:3008
INDUSTRY_RETAIL_URL=http://localhost:3009
INDUSTRY_MANUFACTURING_URL=http://localhost:3010
INDUSTRY_LOGISTICS_URL=http://localhost:3011
INDUSTRY_AUTOMOTIVE_URL=http://localhost:3012
INDUSTRY_TELECOM_URL=http://localhost:3013
INDUSTRY_INSURANCE_URL=http://localhost:3014
INDUSTRY_AGRICULTURE_URL=http://localhost:3015
INDUSTRY_CONSTRUCTION_URL=http://localhost:3016
INDUSTRY_ENERGY_URL=http://localhost:3017
INDUSTRY_MEDIA_URL=http://localhost:3018
INDUSTRY_TRAVEL_URL=http://localhost:3019
INDUSTRY_FITNESS_URL=http://localhost:3020
INDUSTRY_BEAUTY_URL=http://localhost:3021
INDUSTRY_PETCARE_URL=http://localhost:3022
INDUSTRY_HOME_URL=http://localhost:3023
INDUSTRY_EVENTS_URL=http://localhost:3024
INDUSTRY_NONPROFIT_URL=http://localhost:3025
INDUSTRY_GOVERNMENT_URL=http://localhost:3026
INDUSTRY_BANKING_URL=http://localhost:3027
INDUSTRY_INVESTMENT_URL=http://localhost:3028

# =============================================================================
# DATABASE
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/hojai
REDIS_URL=redis://localhost:6379

# =============================================================================
# SECURITY (REQUIRED - NO DEFAULTS)
# Generate strong secrets: openssl rand -base64 32
# =============================================================================
JWT_SECRET=CHANGE_ME_generate_strong_secret_minimum_32_chars
INTERNAL_SERVICE_TOKEN=CHANGE_ME_generate_strong_service_token

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# =============================================================================
# WHATSAPP BUSINESS API (if using WhatsApp integration)
# =============================================================================
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret

# =============================================================================
# OPENAI (if using OpenAI for AI features)
# =============================================================================
OPENAI_API_KEY=sk-your_openai_api_key

# =============================================================================
# RAZORPAY (if using payments)
# =============================================================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# =============================================================================
# DEMO/TESTING
# =============================================================================
DEMO_TENANT_ID=demo_tenant_id
MERCHANT_API_KEY=hojai_your_merchant_api_key