# ============================================================
# Waitron - Restaurant OS for HOJAI
# The Restaurant That Never Stopped Learning
# ============================================================

# Service Configuration
PORT=4820
NODE_ENV=development

# Logging
LOG_LEVEL=info

# ============================================================
# REZ Restaurant Services (RTNM)
# ============================================================
REZ_RESTAURANT_URL=http://localhost:4017
REZ_POS_URL=http://localhost:3100
REZ_ANALYTICS_URL=http://localhost:4019
REZ_INVENTORY_URL=http://localhost:4056
REZ_LOYALTY_URL=http://localhost:4007
REZ_RESERVATIONS_URL=http://localhost:4020
REZ_CRM_URL=http://localhost:4007
REZ_AI_URL=http://localhost:4018
REZ_MIND_URL=http://localhost:4007

# ============================================================
# HOJAI Core
# ============================================================
HOJAI_MEMORY_URL=http://localhost:4520
HOJAI_INTELLIGENCE_URL=http://localhost:4530
HOJAI_BRIDGE_URL=http://localhost:5140

# ============================================================
# Commerce Network
# ============================================================
NEXHA_URL=http://localhost:4399

# ============================================================
# RABTUL (Payments & Auth)
# ============================================================
RABTUL_AUTH_URL=http://localhost:4002
RABTUL_PAYMENT_URL=http://localhost:4001
RABTUL_WALLET_URL=http://localhost:4004
RABTUL_NOTIFICATION_URL=http://localhost:4005

# ============================================================
# External Services
# ============================================================
WEATHER_API_KEY=your_weather_api_key
SENTRY_DSN=your_sentry_dsn

# ============================================================
# Security
# ============================================================
JWT_SECRET=CHANGE_ME_generate_strong_secret_here
INTERNAL_SERVICE_TOKEN=your_internal_service_token
