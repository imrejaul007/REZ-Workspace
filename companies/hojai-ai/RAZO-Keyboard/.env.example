# ============================================================
# RAZO Keyboard v2.1 - Environment Variables
# Copy this file to .env and configure values
# ============================================================

# Application
NODE_ENV=development
PORT=4601

# Service URLs (RAZO Internal)
PREDICTIVE_URL=http://localhost:4640
INTENT_URL=http://localhost:4650
SUGGESTIONS_URL=http://localhost:4651
ACTIONS_URL=http://localhost:4652
COMMANDS_URL=http://localhost:4653
DEEP_LINKS_URL=http://localhost:4654
KEYBOARD_FEED_URL=http://localhost:4655

# Service URLs (RTNM Ecosystem - CORRECTED PORTS)
# Genie Services
GENIE_URL=http://localhost:4706           # Genie Briefing Service
GENIE_GATEWAY=http://localhost:4702         # Genie Personal OS Gateway
GENIE_MEMORY=http://localhost:4703           # Genie Memory Service
GENIE_RELATIONSHIP=http://localhost:4704      # Genie Relationship Service
GENIE_MEETING=http://localhost:4713          # Genie Meeting Service
GENIE_VOICE=http://localhost:4712            # Genie Voice Service
GENIE_CALENDAR=http://localhost:4709         # Genie Calendar Service

# CoPilot Services
COPILOT_URL=http://localhost:4002            # Business CoPilot (24 industries)
COPILOT_GOAL=http://localhost:4242          # Goal OS
COPILOT_FOUNDER=http://localhost:4260        # Founder OS
COPILOT_MEETING=http://localhost:4700        # Meeting Intelligence
COPILOT_PRODUCT=http://localhost:4755         # Product Intelligence
COPILOT_COMPETITIVE=http://localhost:4756     # Competitive Intelligence
COPILOT_REVENUE=http://localhost:4757         # Revenue Intelligence

# Other RTNM Services
CORPID_URL=http://localhost:4701             # CorpID Service
RABTUL_AUTH_URL=http://localhost:4002       # RABTUL Auth
MEMORY_URL=http://localhost:4520             # Memory Tier Service
VOICE_SERVICE_URL=http://localhost:4033      # Voice/STT Service
RELATIONSHIP_URL=http://localhost:4704       # Relationship Service
WALLET_URL=http://localhost:4004            # REZ Wallet
AIRZY_URL=http://localhost:4800              # Airzy Travel

# Redis
REDIS_URL=redis://localhost:6379

# MongoDB
MONGODB_URL=mongodb://localhost:27017/razo

# Security - REQUIRED
JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars
API_KEY=change-this-to-a-strong-api-key
INTERNAL_SERVICE_TOKEN=razo-internal-token

# Encryption for Vault (REQUIRED - AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-this-to-a-32-byte-hex-string-from-openssl-rand-hex-32

# WebAuthn Relying Party ID
WEBAUTHN_RP_ID=razo.app

# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,https://razo.app

# AI Services
WHISPER_MODEL=base
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00tcm4el8am8noocxocnqwd
