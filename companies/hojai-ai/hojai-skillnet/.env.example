# ============================================================
# Hojai-Skillnet - Environment Variables
# Copy this file to .env and configure values
# ============================================================

# Service Configuration
PORT=3000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hojai-skillnet

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
# SECURITY: MUST be at least 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-very-long-and-secure-secret-key-at-least-32-characters-here

# CORS Configuration
# Comma-separated list of allowed origins (no spaces)
# Leave empty for no CORS (recommended for production APIs)
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# RABTUL Services (if integrating)
RABTUL_AUTH_URL=http://localhost:4002
RABTUL_PAYMENT_URL=http://localhost:4001
RABTUL_WALLET_URL=http://localhost:4004
RABTUL_NOTIFICATION_URL=http://localhost:4005

# Service-specific variables
HOJAI-SKILLNET_API_KEY=your_api_key_here
