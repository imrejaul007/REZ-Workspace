# HOJAI AI - Production Environment Variables
# Copy to .env and fill in your values

# ============================================
# AUTHENTICATION
# ============================================

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ============================================
# DATABASE
# ============================================

MONGODB_URI=mongodb://admin:password@localhost:27017/hojai?authSource=admin
MONGO_USER=admin
MONGO_PASSWORD=change-this-password

# ============================================
# CACHE
# ============================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=change-this-password

# ============================================
# API KEYS (Optional)
# ============================================

# OpenAI
OPENAI_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid
SENDGRID_API_KEY=

# MSG91 (SMS)
MSG91_API_KEY=

# Exotel
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=

# LiveKit
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# ============================================
# CORS
# ============================================

CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ============================================
# LOGGING
# ============================================

LOG_LEVEL=info
LOG_FORMAT=json

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# FEATURES
# ============================================

FEATURE_AI_EMPLOYEES=true
FEATURE_VOICE=true
FEATURE_ANALYTICS=true
FEATURE_HYPERLOCAL=false

# ============================================
# SERVICES (Internal)
# ============================================

API_GATEWAY_URL=http://api-gateway:4500
MEMORY_SERVICE_URL=http://memory:4520
INTELLIGENCE_SERVICE_URL=http://intelligence:4530
AGENTS_SERVICE_URL=http://agents:4550
GOVERNANCE_SERVICE_URL=http://governance:4501
EVENT_SERVICE_URL=http://event:4510
