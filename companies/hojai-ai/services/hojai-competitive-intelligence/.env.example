# ============================================================
# HOJAI Competitive Intelligence - Environment Variables
# Port: 4756
# ============================================================

# Service Configuration
PORT=4756
NODE_ENV=production
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hojai-competitive-intelligence

# ============================================================
# AUTHENTICATION (REQUIRED)
# ============================================================
JWT_SECRET=CHANGE_ME_generate_strong_secret_here
HOJAI_COMPETITIVE_INTELLIGENCE_API_KEY=CHANGE_ME_generate_strong_api_key_here

# ============================================================
# CORS (REQUIRED IN PRODUCTION)
# ============================================================
CORS_ORIGIN=https://your-allowed-origin.com

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
