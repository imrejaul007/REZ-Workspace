# ============================================================
# Genie Meeting Service - Environment Variables
# Copy this file to .env and configure values
# ============================================================

# Service Configuration
PORT=4713
NODE_ENV=production
SERVICE_NAME=genie-meeting-service

# MongoDB
MONGODB_URI=mongodb://localhost:27017/genie_meeting

# Redis
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=CHANGE_ME_generate_strong_secret_here
INTERNAL_SERVICE_TOKEN=

# CORS
CORS_ORIGINS=*

# Genie Services
GENIE_MEMORY=http://localhost:4703
GENIE_RELATIONSHIP=http://localhost:4704
GENIE_BRIEFING=http://localhost:4706

# HOJAI Services
HOJAI_GATEWAY=http://localhost:4500
HOJAI_MEMORY=http://localhost:4520
HOJAI_AGENTS=http://localhost:4550
