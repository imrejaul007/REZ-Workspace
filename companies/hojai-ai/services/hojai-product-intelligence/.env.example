# ============================================================
# HOJAI Product Intelligence - Environment Variables
# Port: 4755
# ============================================================

# Service Configuration
PORT=4755
NODE_ENV=production
LOG_LEVEL=info

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hojai-product-intelligence

# ============================================================
# AUTHENTICATION (REQUIRED)
# ============================================================

# JWT Secret - MUST be a strong, unique secret in production
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_generate_strong_secret_here

# API Key for service-to-service authentication
# Generate with: openssl rand -hex 32
HOJAI_PRODUCT_INTELLIGENCE_API_KEY=CHANGE_ME_generate_strong_api_key_here

# ============================================================
# CORS (REQUIRED IN PRODUCTION)
# ============================================================

# Comma-separated list of allowed origins
CORS_ORIGIN=https://your-allowed-origin.com

# ============================================================
# RATE LIMITING
# ============================================================

# Requests per window (default: 100)
RATE_LIMIT_MAX=100

# Window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW=60000
