# ============================================================
# HOJAI Shared Services - Environment Variables
# Copy this file to .env and configure values
# ============================================================

# Service Configuration
PORT=4580
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb://localhost:27017/hojai-shared
REDIS_URL=redis://localhost:6379

# Security (REQUIRED - NO DEFAULTS)
JWT_SECRET=CHANGE_ME_generate_strong_secret_minimum_32_chars
INTERNAL_SERVICE_TOKEN=CHANGE_ME_generate_strong_service_token

# ============================================================
# RABTUL CORE SERVICES (REQUIRED)
# ============================================================
RABTUL_AUTH_URL=http://localhost:4002
RABTUL_PAYMENT_URL=http://localhost:4001
RABTUL_WALLET_URL=http://localhost:4004
RABTUL_NOTIFICATION_URL=http://localhost:4005

# ============================================================
# REZ IDENTITY HUB (REQUIRED)
# ============================================================
REZ_IDENTITY_URL=http://localhost:6000

# ============================================================
# HOJAI SKILLNET (REQUIRED)
# ============================================================
SKILLNET_URL=http://localhost:5130
INTELLIGENCE_URL=http://localhost:5130
RUNTIME_URL=http://localhost:5120

# ============================================================
# HOJAI SERVICES
# ============================================================
BRANDPULSE_URL=http://localhost:4770
