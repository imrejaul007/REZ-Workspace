# HOJAI Goal-OS Environment Variables

# Server Configuration
PORT=4242
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/hojai-goal-os

# CORS Configuration
CORS_ORIGIN=*

# JWT Configuration (for auth middleware)
JWT_SECRET=your-jwt-secret-here

# Service Metadata
SERVICE_NAME=hojai-goal-os
SERVICE_VERSION=1.0.0
