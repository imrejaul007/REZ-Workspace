# REZ Workspace - Environment Configuration
NODE_ENV=development
PORT=3000
SERVICE_NAME=rez-workspace

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-workspace

# JWT
JWT_SECRET=your-jwt-secret-change-in-production

# RABTUL Services
RABTUL_AUTH_URL=http://localhost:4002

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000
