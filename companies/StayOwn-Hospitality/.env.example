# StayOwn Hospitality - Environment Configuration
NODE_ENV=development
PORT=3000
SERVICE_NAME=stayown-hospitality

# MongoDB
MONGODB_URI=mongodb://localhost:27017/stayown
MONGODB_DATABASE=stayown

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production

# RABTUL Services
RABTUL_AUTH_URL=http://localhost:4002
RABTUL_WALLET_URL=http://localhost:4004

# HOJAI AI
HOJAI_GATEWAY_URL=http://localhost:4500

# CORS
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# Monitoring
SENTRY_DSN=
