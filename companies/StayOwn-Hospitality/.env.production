# StayOwn Hospitality - Production Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=production
ALLOWED_ORIGINS=https://stayown.com,https://www.stayown.com

# ============================================
# MONGODB
# ============================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=CHANGE_ME_generate_strong_password
MONGODB_URI=mongodb://admin:CHANGE_ME@mongodb:27017/stayown?authSource=admin

# ============================================
# REDIS
# ============================================
REDIS_PASSWORD=CHANGE_ME_generate_strong_password
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ============================================
# RABBITMQ
# ============================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=CHANGE_ME_generate_strong_password

# ============================================
# SECURITY
# ============================================
JWT_SECRET=CHANGE_ME_generate_64_char_random_string
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d
INTERNAL_SERVICE_TOKEN=CHANGE_ME_generate_32_char_hex_token

# ============================================
# RAZORPAY (Payment Processing)
# ============================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ============================================
# REZ ECOSYSTEM
# ============================================
REZ_MIND_URL=http://rez-mind:4017
REZ_INTENT_GRAPH_URL=http://rez-intent-graph:4015
HOJAI_BRAIN_URL=http://hojai-brain:4530
HOJAI_BRAIN_API_KEY=your_hojai_brain_api_key

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=https://stayown.com
API_URL=https://api.stayown.com
WS_URL=wss://api.stayown.com

# ============================================
# MONITORING
# ============================================
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ============================================
# PORTS (for reference)
# ============================================
# hojai-memory: 4520
# hojai-staybot: 4840
# hojai-genie: 4703
# rez-auth: 4002
# rez-payment: 4001
# rez-wallet: 4004
# ai-front-desk: 3800
# integration-gateway: 3898
# hotel-dashboard: 3000