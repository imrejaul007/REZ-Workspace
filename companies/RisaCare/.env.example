# ===========================================
# RisaCare Environment Variables
# ===========================================

# Service Ports
PORT=4700
RECORDS_PORT=4702
AI_PORT=4703
PROFILE_PORT=4704
BOOKING_PORT=4705
MARKETPLACE_PORT=4706
WELLNESS_PORT=4707
CORPORATE_PORT=4708

# Environment
NODE_ENV=development

# ===========================================
# REZ INTELLIGENCE
# ===========================================
REZ_INTELLIGENCE_URL=http://localhost:4018
REZ_INTELLIGENCE_API_KEY=your-rez-intelligence-api-key
HEALTH_EXPERT_URL=http://localhost:3011
MEMORY_LAYER_URL=http://localhost:4201
SIGNAL_AGGREGATOR_URL=http://localhost:4142

# ===========================================
# RABTUL SERVICES
# ===========================================
AUTH_SERVICE_URL=http://localhost:4002
PAYMENT_SERVICE_URL=http://localhost:4001
WALLET_SERVICE_URL=http://localhost:4004
NOTIFICATION_SERVICE_URL=http://localhost:4011
BOOKING_SERVICE_URL=http://localhost:4020
PROFILE_SERVICE_URL=http://localhost:4013
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# ===========================================
# DATABASE
# ===========================================
MONGODB_URI=mongodb://localhost:27017/risa_care

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# STORAGE
# ===========================================
STORAGE_PROVIDER=local
STORAGE_BUCKET=risa-care-records
STORAGE_BASE_PATH=./storage
# For S3:
# STORAGE_PROVIDER=s3
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ===========================================
# SECURITY
# ===========================================
JWT_SECRET=your-jwt-secret-key
ENCRYPTION_KEY=your-32-character-encryption-key

# ===========================================
# OBSERVABILITY
# ===========================================
SENTRY_DSN=https://xxx@sentry.io/xxx
LOG_LEVEL=info

# ===========================================
# SERVICE VERSION
# ===========================================
SERVICE_VERSION=1.0.0
