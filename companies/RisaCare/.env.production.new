# =============================================================================
# RisaCare - Production Environment Variables
# IMPORTANT: Use these in production deployments
# =============================================================================

# Node Environment
NODE_ENV=production
LOG_LEVEL=info

# ==========================================
# DATABASE CONNECTIONS
# ==========================================

# MongoDB
MONGODB_URI=mongodb://mongo-primary:27017/risa_care
MONGODB_USER=risacare_admin
MONGODB_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# Redis
REDIS_URL=redis://:risacare-redis-pass@redis:6379
REDIS_PASSWORD=risacare-redis-pass

# ==========================================
# SECURITY
# ==========================================

# JWT Configuration
JWT_SECRET=YOUR_JWT_SECRET_HERE_32_CHARS_MIN
JWT_EXPIRES_IN=7d

# API Keys
HOJAI_API_KEY=YOUR_HOJAI_API_KEY
ABHA_API_KEY=YOUR_ABHA_API_KEY

# Encryption
ENCRYPTION_KEY=YOUR_32_CHAR_ENCRYPTION_KEY

# ==========================================
# EXTERNAL SERVICES
# ==========================================

# HOJAI AI
HOJAI_LLM_URL=http://hojai-llm:4730
HOJAI_VOICE_URL=http://hojai-voice:4590

# RABTUL (Auth + Payment)
RABTUL_AUTH_URL=http://rabtul-auth:4002
RABTUL_PAYMENT_URL=http://rabtul-payment:4001
RABTUL_NOTIFICATION_URL=http://rabtul-notify:4011

# REZ Intelligence
REZ_INTELLIGENCE_URL=http://rez-intelligence:3000
HEALTH_EXPERT_URL=http://health-expert:3011

# ==========================================
# STORAGE (S3 Compatible)
# ==========================================

AWS_REGION=ap-south-1
S3_BUCKET=risacare-documents
AWS_ACCESS_KEY_ID=YOUR_AWS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET

# ==========================================
# MONITORING
# ==========================================

# Prometheus/Grafana
GRAFANA_PASSWORD=YOUR_GRAFANA_PASSWORD

# Sentry Error Tracking (Optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ==========================================
# HEALTHCARE SPECIFIC
# ==========================================

# ABHA (India Digital Health)
ABHA_API_URL=https://abha.abdm.gov.in/abha/v1

# WebRTC
WEBRTC_STUN_URL=stun:stun.l.google.com:19302

# FHIR Server
FHIR_BASE_URL=http://fhir-server:8080/fhir

# ==========================================
# RATE LIMITING
# ==========================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# FEATURE FLAGS
# ==========================================

ENABLE_AI_INTERPRETATION=true
ENABLE_FHIR_SYNC=true
ENABLE_ABHA_INTEGRATION=true
ENABLE_TELECONSULT=true