{
  "name": "@rez-tech/developer-platform",
  "version": "1.0.0",
  "description": "REZ Developer Platform - Partner SDK, API Docs, Sandbox, and Webhooks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
