    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
