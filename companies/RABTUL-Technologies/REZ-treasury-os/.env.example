# TreasuryOS Environment Variables

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-treasury

# Redis
REDIS_URL=redis://localhost:6379

# Service
PORT=4055
NODE_ENV=development

# Internal Authentication
INTERNAL_SERVICE_TOKEN=your-secure-token-here

# Connected Services
WALLET_SERVICE_URL=http://localhost:4004
PAYMENT_SERVICE_URL=http://localhost:4001
AUTH_SERVICE_URL=http://localhost:4002

# Forecasting
FORECAST_HISTORY_DAYS=90
FORECAST_WEEKS_AHEAD=13

# Investment APIs
FIXED_DEPOSIT_API_URL=https://api.bank.example.com
MONEY_MARKET_API_URL=https://api.money-market.example.com

# Notifications
NOTIFICATIONS_SERVICE_URL=http://localhost:4010

# Sentry
SENTRY_DSN=
