# RABTUL Services - Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED - Must be set before running any service
# =============================================================================

# Internal Service Authentication (REQUIRED - do not use default in production)
INTERNAL_SERVICE_TOKEN=generate_with_openssl_rand_hex_32

# Grafana Admin Password (REQUIRED for observability stack)
GRAFANA_ADMIN_PASSWORD=change_this_secure_password
GRAFANA_ADMIN_USER=admin

# =============================================================================
# Database
# =============================================================================

MONGODB_URI=mongodb://localhost:27017/service-db
MONGODB_URI_TEST=mongodb://localhost:27017/service-db-test

# =============================================================================
# Redis
# =============================================================================

REDIS_URL=redis://localhost:6379
# Or use individual components:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# =============================================================================
# Node Environment
# =============================================================================

NODE_ENV=development
PORT=4025

# =============================================================================
# CORS (comma-separated list of allowed origins)
# =============================================================================

CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# =============================================================================
# AI/ML Services
# =============================================================================

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_URL=https://api.openai.com/v1

# =============================================================================
# External Service URLs
# =============================================================================

AUTH_SERVICE_URL=http://localhost:4002
PAYMENT_SERVICE_URL=http://localhost:4001
WALLET_SERVICE_URL=http://localhost:4004
WORKFLOW_BUILDER_URL=http://localhost:4045
REZ_SCHEDULE_API_URL=http://localhost:4090
REZ_SCHEDULE_API_KEY=

# =============================================================================
# Rate Limiting
# =============================================================================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Observability
# =============================================================================

SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
