# BIZORA Compliance Service - Environment Variables

# Server Configuration
PORT=4002
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/bizora-compliance
MONGODB_MAX_POOL_SIZE=10

# JWT Configuration (for internal service auth)
JWT_SECRET=bizora-compliance-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# CORS Configuration
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info

# Internal Service Token (for inter-service communication)
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# Optional: External Services
# GST_PORTAL_API_URL=https://api.gst.gov.in
# GST_PORTAL_API_KEY=your-gst-api-key

# Optional: Monitoring
# SENTRY_DSN=https://xxx@sentry.io/xxx
# PROMETHEUS_PORT=9090