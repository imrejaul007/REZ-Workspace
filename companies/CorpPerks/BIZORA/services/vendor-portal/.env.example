# Server Configuration
PORT=4515
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/bizora_vendor_portal

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=*

# Service URLs
CORPPERKS_API_URL=http://localhost:4700
REZ_AUTH_URL=http://localhost:4002
REZ_WALLET_URL=http://localhost:4004
