# Server Configuration
PORT=4010
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/bizora_invoices

# Logging
LOG_LEVEL=info

# Company Information (for PDF generation)
COMPANY_NAME=BIZORA
COMPANY_ADDRESS=Your Company Address, City, State, PIN
COMPANY_PHONE=+91-XXXXXXXXXX
COMPANY_EMAIL=accounts@bizora.com

# Email Configuration (for sending invoices)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# RABTUL Integration (for notifications)
REZ_AUTH_SERVICE_URL=http://localhost:4002
REZ_NOTIFICATION_SERVICE_URL=http://localhost:4011
INTERNAL_SERVICE_TOKEN=your-internal-service-token

# JWT Configuration
JWT_SECRET=your-jwt-secret-key

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
