# Trust Escrow Service Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=4008
NODE_ENV=development
LOG_LEVEL=info

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/trust-escrow

# CORS Configuration
CORS_ORIGIN=*

# Authentication
# For development, use simple base64 encoded userId:role
# For production, use proper JWT tokens
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Service-to-Service Authentication
# Internal token for microservice communication
INTERNAL_SERVICE_TOKEN=your-internal-service-token-change-in-production

# Platform Fee Configuration (optional overrides)
# PLATFORM_FEE_PERCENTAGE=2.5
# PLATFORM_FEE_FIXED=0
# PLATFORM_FEE_CHARGED_TO=split

# Escrow Expiration (in days)
# DEFAULT_ESCROW_EXPIRATION_DAYS=30

# Redis (optional - for caching and pub/sub)
# REDIS_URL=redis://localhost:6379

# Rate Limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
