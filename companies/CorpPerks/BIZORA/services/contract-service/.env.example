# Server Configuration
PORT=4000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/bizora-contracts

# CORS Configuration
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# Service Authentication (for internal service calls)
INTERNAL_SERVICE_TOKEN=your-internal-service-token-here

# Optional: PDF Storage
# PDF_STORAGE_PATH=/tmp/contracts

# Optional: Redis (for caching)
# REDIS_URL=redis://localhost:6379