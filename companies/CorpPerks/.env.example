# CorpPerks - Environment Variables
# Copy to .env.local for development or configure in production

# ============================================
# REZ RABTUL Services (External)
# ============================================

REZ_AUTH_URL=https://rez-auth-service.onrender.com
REZ_PROFILE_URL=https://rez-profile-service.onrender.com
REZ_WALLET_URL=https://rez-wallet-service.onrender.com
REZ_PAYMENT_URL=https://rez-payment-service.onrender.com
REZ_NOTIFICATIONS_URL=https://rez-notifications-service.onrender.com
REZ_ANALYTICS_URL=https://rez-analytics-service.onrender.com
REZ_REFERRAL_URL=https://rez-referral-service.onrender.com
REZ_REWARDS_URL=https://rez-rewards-service.onrender.com
REZ_GAMIFICATION_URL=https://rez-gamification-service.onrender.com

# ============================================
# REZ Intelligence (External)
# ============================================

REZ_INTENT_URL=https://rez-intent-predictor.rezapp.com
REZ_PREDICTIVE_URL=https://rez-predictive-engine.rezapp.com
REZ_INSIGHTS_URL=https://rez-insights-service.rezapp.com
REZ_CAREER_GRAPH_URL=https://rez-career-graph.rezapp.com

# ============================================
# Database
# ============================================

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/corpperks
REDIS_URL=redis://localhost:6379

# ============================================
# Internal Service Auth
# ============================================

INTERNAL_SERVICE_TOKEN=your-secure-token-here

# ============================================
# App Settings
# ============================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=info
LOG_PRETTY=true

# ============================================
# Service URLs (API Gateway Routes)
# Update these for production deployment
# ============================================

# Core Services
BACKEND_URL=http://localhost:4006
CORP_INTEL_URL=http://localhost:4135

# HRMS Services
PROJECTOS_URL=http://localhost:4715
TEAM_COLLAB_URL=http://localhost:4716
MEETING_URL=http://localhost:4728
PERFORMANCE_URL=http://localhost:4729
OKR_URL=http://localhost:4730
WORKFLOW_URL=http://localhost:4731
ONBOARDING_URL=http://localhost:4732
EXIT_URL=http://localhost:4733
LMS_URL=http://localhost:4734
REPORTS_URL=http://localhost:4735
CALENDAR_URL=http://localhost:4736
SSO_URL=http://localhost:4737
PAYROLL_URL=http://localhost:4738
SHIFT_URL=http://localhost:4739
COMPENSATION_URL=http://localhost:4740
DOCUMENT_URL=http://localhost:4741
VIDEO_URL=http://localhost:4742

# CRM & Identity
CORP_CRM_URL=http://localhost:4725
CORPID_URL=http://localhost:4701

# Analytics & Integrations
ANALYTICS_URL=http://localhost:4744
PUSH_URL=http://localhost:4743
WHATSAPP_URL=http://localhost:4745
GRAPHQL_URL=http://localhost:4747
WEBHOOK_URL=http://localhost:4746
REALTIME_URL=http://localhost:4748

# CorpID Services
CORPID_PROFILE_URL=http://localhost:4723

# Bridges
REZ_MERCHANT_URL=http://localhost:4008
HOJAI_AGENTS_URL=http://localhost:4550
HOJAI_COMM_URL=http://localhost:4590
HOJAI_FLOW_URL=http://localhost:4560
RIDZA_URL=http://localhost:4600
RISNAESTATE_URL=http://localhost:4700

# ============================================
# CorpID Integration
# ============================================

CORPID_SERVICE_URL=http://localhost:4702
CORPID_INTERNAL_TOKEN=corpid-internal-token
CORPID_SYNC_ON_CREATE=true
CORPID_SYNC_ON_UPDATE=true
CORPID_SYNC_ON_DELETE=true
CORPID_TIMEOUT=10000

# ============================================
# JWT & Security
# ============================================

JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ============================================
# Third-party Services
# ============================================

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@corpperks.com

# Twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=corpperks-uploads
AWS_REGION=ap-south-1

# WhatsApp Business API
WHATSAPP_BUSINESS_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# ============================================
# Feature Flags
# ============================================

ENABLE_TWO_FACTOR_AUTH=false
ENABLE_WHATSAPP_NOTIFICATIONS=false
ENABLE_BIOMETRIC_ATTENDANCE=false
ENABLE_AI_FEATURES=true

# ============================================
# Monitoring & Observability
# ============================================

SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
DATADOG_API_KEY=your-datadog-api-key
PROMETHEUS_ENABLED=true