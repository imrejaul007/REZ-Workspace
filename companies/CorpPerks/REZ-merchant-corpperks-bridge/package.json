  "description": "CorpPerks to REZ-Merchant integration service for employee benefits, GST invoicing, and HRIS sync",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "corpperks",
    "rez-merchant",
    "employee-benefits",
    "gst",
    "hris",
    "integration"
  ],
