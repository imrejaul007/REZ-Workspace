{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "regions": ["sin1"],
  "env": {
    "NEXT_PUBLIC_API_URL": "https://corpperks-api.onrender.com",
    "NEXT_PUBLIC_LMS_URL": "https://corpperks-lms.onrender.com",
    "NEXT_PUBLIC_CALENDAR_URL": "https://corpperks-calendar.onrender.com"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
