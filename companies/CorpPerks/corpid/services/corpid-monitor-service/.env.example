# =============================================================================
# CorpID Monitor Service - Production Environment Variables
# =============================================================================
# Port: 4711
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=4711

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/corpid_monitor?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_TOKEN=generate-secure-internal-service-token

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://corpid.corpperks.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Monitoring Configuration
# -----------------------------------------------------------------------------
# Alert thresholds
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=85
ALERT_ERROR_RATE_THRESHOLD=5

# Metrics retention (days)
METRICS_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
