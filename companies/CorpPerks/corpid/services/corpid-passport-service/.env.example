# =============================================================================
# CorpID Passport Service - Production Environment Variables
# =============================================================================
# Port: 4704
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=4704

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/corpid_passport?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_TOKEN=generate-secure-internal-service-token

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://corpid.corpperks.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Passport Configuration
# -----------------------------------------------------------------------------
# Passport expiration warnings (days before)
PASSPORT_EXPIRY_WARNING_DAYS=90
PASSPORT_EXPIRY_CRITICAL_DAYS=30

# Verification requirements
REQUIRE_ADDRESS_VERIFICATION=true
REQUIRE_EMPLOYMENT_VERIFICATION=true
REQUIRE_DOCUMENT_VERIFICATION=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
