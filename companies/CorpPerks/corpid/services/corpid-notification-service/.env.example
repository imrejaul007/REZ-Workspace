# =============================================================================
# CorpID Notification Service - Production Environment Variables
# =============================================================================
# Port: 4708
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=4708

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/corpid_notifications?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_TOKEN=generate-secure-internal-service-token

# -----------------------------------------------------------------------------
# SendGrid Configuration
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@corpperks.com
EMAIL_FROM_NAME=CorpPerks

# -----------------------------------------------------------------------------
# Twilio Configuration
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Push Notifications
# -----------------------------------------------------------------------------
# Firebase Cloud Messaging
FCM_SERVER_KEY=your-fcm-server-key

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your-expo-access-token

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://corpid.corpperks.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email rate limiting
EMAIL_RATE_LIMIT=100
SMS_RATE_LIMIT=50

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
