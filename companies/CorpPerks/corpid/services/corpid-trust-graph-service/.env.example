# =============================================================================
# CorpID Trust Graph Service - Production Environment Variables
# =============================================================================
# Port: 4702
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=4702

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/corpid_trust?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_TOKEN=generate-secure-internal-service-token

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://corpid.corpperks.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Trust Score Configuration
# -----------------------------------------------------------------------------
TRUST_DECAY_ENABLED=true
TRUST_DECAY_DAYS=90
MIN_TRUST_SCORE=0
MAX_TRUST_SCORE=100

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
