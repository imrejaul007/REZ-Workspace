# =============================================================================
# CorpID API Gateway - Production Environment Variables
# =============================================================================
# Port: 4700
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=4700

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/corpid?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_TOKEN=generate-secure-internal-service-token

# -----------------------------------------------------------------------------
# CorpID Services URLs (internal)
# -----------------------------------------------------------------------------
CORPID_IDENTITY_URL=http://corpid-identity-service:4701
CORPID_TRUST_GRAPH_URL=http://corpid-trust-graph-service:4702
CORPID_VERIFICATION_URL=http://corpid-verification-service:4703
CORPID_PASSPORT_URL=http://corpid-passport-service:4704
CORPID_CI_SCORE_URL=http://corpid-ci-score-service:4705
CORPID_RISK_URL=http://corpid-risk-service:4706

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://corpid.corpperks.com,https://admin.corpperks.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
