# =============================================================================
# CorpID CI Score Service - Production Environment Variables
# =============================================================================
# Port: 4705
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=4705

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/corpid_ci?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_TOKEN=generate-secure-internal-service-token

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://corpid.corpperks.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# CI Score Configuration
# -----------------------------------------------------------------------------
# Score calculation weights
EMPLOYMENT_WEIGHT=0.3
IDENTITY_WEIGHT=0.25
DOCUMENT_WEIGHT=0.2
TRUST_WEIGHT=0.15
ACTIVITY_WEIGHT=0.1

# Score refresh interval (hours)
SCORE_REFRESH_INTERVAL=24

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
