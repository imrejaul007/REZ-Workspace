# =============================================================================
# CorpID Document Service - Production Environment Variables
# =============================================================================
# Port: 4707
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=4707

# -----------------------------------------------------------------------------
# MongoDB Configuration
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/corpid_documents?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
INTERNAL_SERVICE_TOKEN=generate-secure-internal-service-token

# -----------------------------------------------------------------------------
# Storage Configuration
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=local  # Options: local, s3, gcs
STORAGE_PATH=/data/uploads

# For AWS S3:
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET=corpperks-documents
# AWS_REGION=ap-south-1

# For Google Cloud Storage:
# STORAGE_PROVIDER=gcs
# GCS_PROJECT_ID=your-project-id
# GCS_BUCKET=corpperks-documents
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# -----------------------------------------------------------------------------
# File Upload Settings
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx

# Document retention (days)
DOCUMENT_RETENTION_DAYS=2555

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://corpid.corpperks.com

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
