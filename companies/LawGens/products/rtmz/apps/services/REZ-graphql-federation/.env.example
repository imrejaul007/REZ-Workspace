# Server Configuration
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez-federation-gateway

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# REST Service Endpoints
COMPANY_MEMORY_SERVICE_URL=http://localhost:4801
AGENT_PROTOCOL_SERVICE_URL=http://localhost:4201
HOJAI_API_SERVICE_URL=http://localhost:4500
