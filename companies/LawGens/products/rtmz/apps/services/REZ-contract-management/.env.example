# Server Configuration
PORT=5003
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/rez_contract_management
MONGODB_USER=
MONGODB_PASSWORD=

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-change-in-production

# Email Configuration (for signature notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=REZ Contract Management <noreply@rez.com>

# Frontend URL for signature links
FRONTEND_URL=http://localhost:3000

# Contract Settings
CONTRACT_SIGNATURE_EXPIRY_DAYS=30
CONTRACT_REMINDER_DAYS_BEFORE=30
CONTRACT_MAX_FILE_SIZE_MB=10

# PDF Settings
PDF_OUTPUT_DIR=./generated-pdfs
