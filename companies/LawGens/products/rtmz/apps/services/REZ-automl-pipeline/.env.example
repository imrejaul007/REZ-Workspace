# Server Configuration
PORT=5001
NODE_ENV=development

# Python Configuration
PYTHON_PATH=python3
PYTHON_SCRIPTS_PATH=./python/automl

# Redis Configuration (for job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Model Storage
MODEL_STORAGE_PATH=./models
EXPERIMENT_DATA_PATH=./experiments

# Training Configuration
MAX_CONCURRENT_JOBS=4
JOB_TIMEOUT_MS=3600000
DEFAULT_CV_FOLDS=5
DEFAULT_HYPERPARAM_ITERATIONS=30

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/automl.log

# Feature Store Integration
FEATURE_STORE_URL=http://localhost:5003
FEATURE_STORE_API_KEY=

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=5002
