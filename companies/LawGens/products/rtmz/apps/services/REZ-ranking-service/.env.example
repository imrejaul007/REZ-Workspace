# Server
PORT=5006
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez_ranking

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Python ML Service
ML_SERVICE_URL=http://localhost:5007
ML_SERVICE_ENABLED=true

# Feature Store
FEATURE_CACHE_TTL=3600
FEATURE_MAX_SIZE=10000

# Ranking Defaults
DEFAULT_LIMIT=20
MAX_LIMIT=100
DEFAULT_DIVERSITY=0.3
DEFAULT_PERSONALIZATION=0.5

# A/B Testing
MIN_SAMPLE_SIZE=100
STATISTICAL_CONFIDENCE=0.95
BANDIT_TTL=3600

# Logging
LOG_LEVEL=info
