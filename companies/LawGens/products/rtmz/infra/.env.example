# RTMZ Environment Variables Template
# Copy to .env and fill in values

# =====================
# AUTH SECRETS (REQUIRED)
# =====================

# JWT signing secret (generate a new one for production!)
JWT_SECRET=rez123secret456jwt789token012secret345

# Role-scoped JWT secrets
JWT_MERCHANT_SECRET=merchant789secret012jwt345token678secret901
JWT_ADMIN_SECRET=admin901secret234jwt567token890secret123
JWT_REFRESH_SECRET=refresh456secret789jwt012token345secret678

# Internal service tokens (JSON format)
INTERNAL_SERVICE_TOKENS={"graphql-gateway":"graphql-internal-token","automl":"automl-internal-token","invoice-ocr":"invoice-internal-token","contract-mgmt":"contract-internal-token","legal-ai":"legal-internal-token","cosmic-twin":"cosmic-internal-token","ranking":"ranking-internal-token","mcp-servers":"mcp-internal-token"}

# =====================
# DATABASE
# =====================

MONGODB_URI=mongodb://localhost:27017/rtmz
REDIS_URL=redis://localhost:6379

# =====================
# CORS
# =====================

CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# =====================
# OAUTH PROVIDERS (Optional)
# =====================

# Okta
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_DOMAIN=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =====================
# AI SERVICES
# =====================

ANTHROPIC_API_KEY=sk-ant-...

# =====================
# EMAIL (for contracts)
# =====================

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# =====================
# PRODUCTION FLAGS
# =====================

NODE_ENV=production
LOG_LEVEL=info