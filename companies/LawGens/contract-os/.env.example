# Contract OS Configuration
PORT=4190
NODE_ENV=production
MONGODB_URI=mongodb://localhost:27017/contract-os
JWT_SECRET=CHANGE_ME_generate_strong_secret_here
ENCRYPTION_KEY=CHANGE_ME_generate_another_secret_here
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Contract Defaults
CONTRACT_EXPIRY_DAYS=365
AUTO_RENEW_ENABLED=false
MAX_EXECUTION_RETRIES=3

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# Service Specific
CONTRACT_OS_API_KEY=your_api_key_here
INTERNAL_SERVICE_TOKEN=your-internal-service-token
