# ============================================
# LawGens - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=5099

# ============================================
# MONGODB
# ============================================
MONGODB_URI=mongodb://localhost:27017/lawgens
# For production, use MongoDB Atlas or a managed service
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/lawgens?retryWrites=true&w=majority

# ============================================
# SECURITY - CRITICAL FOR PRODUCTION
# ============================================
# Generate secure secrets: openssl rand -base64 32
JWT_SECRET=your-32-character-minimum-secret-key-here
ENCRYPTION_KEY=another-32-character-minimum-secret-key-here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS - Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# ============================================
# REDIS (Optional - for caching)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ============================================
# ELASTICSEARCH (Optional - for legal search)
# ============================================
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX=lawgens-documents
ES_TIMEOUT=30000

# ============================================
# HOJAI AI INTEGRATION
# ============================================
HOJAI_GATEWAY_URL=http://localhost:4500
HOJAI_API_KEY=your-hojai-api-key
HOJAI_TIMEOUT=30000
HOJAI_RETRY=3

# ============================================
# LEGAL RESEARCH APIs
# ============================================
CASE_LAW_ENDPOINT=https://api.case.law/v1/cases
STATUTE_ENDPOINT=https://api.law.example.com/statutes
MAX_RESEARCH_RESULTS=50
CACHE_DURATION=3600000

# ============================================
# COURT APIs
# ============================================
PACER_URL=https://ecf.uscourts.gov
COURT_API_KEY=your-court-api-key
COURTS_URL=https://api.courts.example.com

# ============================================
# STORAGE
# ============================================
STORAGE_TYPE=local
STORAGE_PATH=./documents
# For S3:
# STORAGE_TYPE=s3
# S3_BUCKET=lawgens-documents
# S3_REGION=us-east-1

# ============================================
# EMAIL (for notifications)
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=lawgens@rtnm.digital

# ============================================
# INTERNAL SERVICES
# ============================================
INTERNAL_SERVICE_TOKEN=your-internal-service-token
UNIFIED_HUB_URL=http://localhost:4600

# Service URLs
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com
HOJAI_MEMORY=http://localhost:4520
HOJAI_INTELLIGENCE=http://localhost:4530
HOJAI_AGENTS=http://localhost:4550

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/lawgens.log

# ============================================
# FEATURE FLAGS
# ============================================
FEATURE_AI_ANALYSIS=true
FEATURE_E_DISCOVERY=true
FEATURE_COURT_TRACKING=true
FEATURE_COMPLIANCE_MONITORING=true
FEATURE_DOCUMENT_DRAFTING=true

# ============================================
# CONTRACT DEFAULTS
# ============================================
CONTRACT_EXPIRY_DAYS=365
MAX_CLAUSES=100
MAX_PARTIES=10
AUTO_RENEW_ENABLED=false
MAX_EXECUTION_RETRIES=3

# ============================================
# PAGINATION
# ============================================
PAGINATION_LIMIT=20
PAGINATION_MAX=100

# ============================================
# ENDPOINT RATE LIMITS
# ============================================
LIMIT_LEGAL_RESEARCH=30
LIMIT_CONTRACT_ANALYSIS=20
LIMIT_COMPLIANCE=10
LIMIT_COURT=30
LIMIT_DOCUMENT=20