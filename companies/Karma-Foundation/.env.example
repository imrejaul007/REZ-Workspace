# ===========================================
# Karma Foundation - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit .env files to version control
# ===========================================

# ===========================================
# Core Settings
# ===========================================
PORT=3000
NODE_ENV=development

# ===========================================
# Database Configuration
# ===========================================
MONGODB_URI=mongodb://localhost:27017/karma
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_AUTH_SOURCE=admin

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===========================================
# Authentication & Security
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

QR_SECRET=your-qr-signing-secret-min-32-chars
QR_EXPIRES_IN=300

INTERNAL_SERVICE_TOKEN=your-internal-service-token-min-32-chars

# Admin access token for administrative operations
ADMIN_TOKEN=your-admin-token-min-32-chars

# CORS whitelist (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# ===========================================
# Service URLs (for inter-service communication)
# ===========================================
AUTH_SERVICE_URL=http://localhost:3000
WALLET_SERVICE_URL=http://localhost:3000
MERCHANT_SERVICE_URL=http://localhost:3000
LOYALTY_BRIDGE_URL=http://localhost:3001

# ===========================================
# External Service URLs
# ===========================================
API_BASE_URL=http://localhost:3000
WEB_URL=http://localhost:3002
MOBILE_SCHEME=karmaapp

# WebSocket URL
WS_URL=ws://localhost:3000

# ===========================================
# Monitoring & Observability
# ===========================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# File Upload Settings
# ===========================================
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# ===========================================
# Email Configuration (optional)
# ===========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@karma.foundation
EMAIL_ENABLED=false

# ===========================================
# SMS Configuration (optional)
# ===========================================
SMS_PROVIDER=
SMS_API_KEY=
SMS_ENABLED=false

# ===========================================
# Payment Gateway (optional)
# ===========================================
PAYMENT_PROVIDER=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=
PAYMENT_ENABLED=false

# ===========================================
# Karma Service (.env)
# ===========================================
# Main API service environment variables
# Located at: karma-service/.env

# ===========================================
# Karma Loyalty Bridge (.env)
# ===========================================
# Loyalty bridge service environment variables
# Located at: karma-loyalty-bridge/.env

# -------------------------------------------
# karma-loyalty-bridge-specific overrides
# -------------------------------------------
BRIDGE_PORT=3001
BRIDGE_NODE_ENV=development

# Service endpoints for loyalty operations
LOYALTY_MERCHANT_API_URL=http://localhost:3000
LOYALTY_WALLET_API_URL=http://localhost:3000
LOYALTY_AUTH_VALIDATION_URL=http://localhost:3000

# Bridge-specific settings
BRIDGE_RETRY_ATTEMPTS=3
BRIDGE_RETRY_DELAY_MS=1000
BRIDGE_TIMEOUT_MS=30000

# ===========================================
# Karma Web (.env.local or .env.production)
# ===========================================
# Next.js web application environment variables
# Located at: karma-web/.env.local

# -------------------------------------------
# karma-web-specific overrides
# -------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_APP_NAME=Karma Foundation
NEXT_PUBLIC_APP_VERSION=1.0.0

# Analytics (optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=

# ===========================================
# Karma Mobile (.env)
# ===========================================
# Expo/React Native mobile app environment variables
# Located at: karma-mobile/.env

# -------------------------------------------
# karma-mobile-specific overrides
# -------------------------------------------
API_URL=http://localhost:3000
WS_URL=ws://localhost:3000

# Environment
APP_ENV=development
APP_VERSION=1.0.0
APP_BUILD_NUMBER=1

# Push Notifications
EXPO_PUSH_API_URL=https://exp.host/--/api/v2/push
PUSH_NOTIFICATIONS_ENABLED=false

# ===========================================
# Development Overrides
# ===========================================
# These should only be set in development
DEBUG=false
INSPECT=false
```

---

## Production Environment Template

For production deployments, copy `.env.example` to `.env.production` and update:

```bash
# Production values
NODE_ENV=production
PORT=3000

MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/karma
REDIS_URL=rediss://user:pass@redis.cloud.com:6379

JWT_SECRET=<generate-secure-64-char-secret>
QR_SECRET=<generate-secure-64-char-secret>
INTERNAL_SERVICE_TOKEN=<generate-secure-64-char-secret>
ADMIN_TOKEN=<generate-secure-64-char-secret>

CORS_ORIGIN=https://karma.foundation,https://www.karma.foundation

AUTH_SERVICE_URL=https://api.karma.foundation
WALLET_SERVICE_URL=https://api.karma.foundation
MERCHANT_SERVICE_URL=https://api.karma.foundation
LOYALTY_BRIDGE_URL=https://loyalty.karma.foundation

SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

LOG_LEVEL=warn
```

---

## Security Notes

1. **Never commit .env files** - They are excluded via .gitignore
2. **Use strong secrets** - Minimum 32 characters for JWT/QR secrets
3. **Rotate regularly** - Change secrets every 90 days in production
4. **Use secrets manager** - Consider AWS Secrets Manager, HashiCorp Vault, or similar
5. **Validate in CI/CD** - Ensure required env vars are set before deployment

### Generating Secure Secrets

```bash
# Using OpenSSL
openssl rand -base64 32

# Using Node.js
node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Using dd
dd if=/dev/urandom bs=32 count=1 2>/dev/null | base64
```