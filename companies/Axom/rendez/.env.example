# Rendez Backend Environment Variables
# Copy to .env and fill in values

# Server
PORT=4060
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rendez

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Internal Service Token (required)
INTERNAL_SERVICE_TOKEN=

# Auth Service
AUTH_SERVICE_URL=http://localhost:4002

# REZ Services
REZ_TRUST_OS_URL=http://localhost:4050
REZ_EMOTIONAL_INTELLIGENCE_URL=http://localhost:4051