# ============================================================
# RisnaEstate - Production Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================================

# ============================================================
# SECURITY (REQUIRED)
# ============================================================

# JWT Secret - Generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Internal Service Token - Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=your-internal-service-token-32-chars

# ============================================================
# CORS & DOMAINS
# ============================================================

# Comma-separated list of allowed origins
CORS_ORIGIN=https://risnaestate.com,https://www.risnaestate.com

# ============================================================
# DATABASE
# ============================================================

# MongoDB URI (use replica set for production)
MONGODB_URI=mongodb://mongo:27017/risnaestate

# Alternative: MongoDB Atlas
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/risnaestate?retryWrites=true&w=majority

# ============================================================
# REDIS
# ============================================================

# Redis URL
REDIS_URL=redis://redis:6379

# Alternative: Redis Cloud
# REDIS_URL=rediss://default:password@redis-host:6379

# ============================================================
# RABTUL SERVICES (REZ Ecosystem)
# ============================================================

# Auth Service
RABTUL_AUTH_URL=http://host.docker.internal:4002

# Payment Service
RABTUL_PAYMENT_URL=http://host.docker.internal:4001

# Wallet Service
RABTUL_WALLET_URL=http://host.docker.internal:4004

# Notification Service
RABTUL_NOTIFICATION_URL=http://host.docker.internal:4011

# Event Bus
RABTUL_EVENT_BUS_URL=http://host.docker.internal:4025

# ============================================================
# REZ INTELLIGENCE SERVICES
# ============================================================

# REZ Intelligence (NRI/HNI/Investor scoring)
REZ_INTELLIGENCE_URL=http://host.docker.internal:4018

# REZ Media (Campaigns, DOOH, QR)
REZ_MEDIA_URL=http://host.docker.internal:4068

# REZ Notifications
REZ_NOTIFICATIONS_URL=http://host.docker.internal:4011

# ============================================================
# EXTERNAL APIs
# ============================================================

# CorpPerks Integration
CORPPERKS_API_URL=https://corpperks.rez.app

# AdsBazaar Integration
ADSBazaar_API_URL=https://adsbazaar.rez.app

# ============================================================
# PAYMENT GATEWAY (Razorpay)
# ============================================================

# Razorpay API Keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Webhook Secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ============================================================
# WHATSAPP BUSINESS API
# ============================================================

WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# ============================================================
# EMAIL (SMTP)
# ============================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@risnaestate.com

# ============================================================
# FILE STORAGE (S3-compatible)
# ============================================================

S3_BUCKET=risnaestate-uploads
S3_REGION=me-south-1
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_ENDPOINT=https://s3.me-south-1.amazonaws.com

# ============================================================
# SMS (Twilio)
# ============================================================

TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================
# PUSH NOTIFICATIONS (Firebase)
# ============================================================

FIREBASE_PROJECT_ID=risnaestate-prod
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# ============================================================
# ANALYTICS
# ============================================================

# Google Analytics
GA_TRACKING_ID=G-XXXXXXXXXX

# Segment
SEGMENT_WRITE_KEY=your_segment_write_key

# ============================================================
# LOGGING & MONITORING
# ============================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Sentry DSN for error tracking
SENTRY_DSN=https://example@sentry.io/1234567

# ============================================================
# NODE ENVIRONMENT
# ============================================================

NODE_ENV=production