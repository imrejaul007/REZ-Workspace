{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": {
      "phases": {
        "setup": {
          "nixPackages": ["nodejs_20"]
        },
        "install": {
          "commands": ["npm install"]
        },
        "build": {
          "commands": ["npm run build"]
        }
      }
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "port": 3000
  }
}
