    "@react-navigation/native-stack": "^7.0.0",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.0.0",
    "expo": "~53.0.0",
    "expo-av": "~15.1.0",
    "expo-constants": "~17.0.0",
    "expo-device": "~7.0.0",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.0",
    "expo-image-picker": "~16.0.0",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~7.0.0",
