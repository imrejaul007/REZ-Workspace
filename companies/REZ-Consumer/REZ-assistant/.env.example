# ===========================================
# REZ Assistant Service - Production Config
# ===========================================

# Server
PORT=3010
NODE_ENV=production
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/rez-assistant
MONGODB_USER=
MONGODB_PASSWORD=

# Security
INTERNAL_API_KEY=CHANGE_ME_generate_strong_api_key_here
ALLOWED_ORIGINS=https://rez.money,https://www.rez.money,https://app.rez.money

# External Service APIs
MIND_API=https://REZ-mind.onrender.com
INTENT_API=https://rez-intent-graph.onrender.com
AGENT_API=https://REZ-agent.onrender.com

# Anthropic API (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
