{
  "extends": "expo/tsconfig.base.json",
  "compilerOptions": {
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noEmit": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@rez/ui": [
        "../../packages/rez-ui/src"
      ],
      "@rez/shared-types": [
        "../../packages/shared-types/src"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src",
    "components"
  ],
  "exclude": [
    "node_modules",
    "tests.bak",
    "tests",
    "__tests__",
    "__mocks__",
    "e2e",
    "scripts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
