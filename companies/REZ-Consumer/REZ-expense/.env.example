# ===========================================
# REZ Expense Service - Production Config
# ===========================================

# Server
PORT=3013
NODE_ENV=production
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/rez-expense
MONGODB_USER=
MONGODB_PASSWORD=

# Security
INTERNAL_API_KEY=CHANGE_ME_generate_strong_api_key_here

# RABTUL Services
RABTUL_AUTH_URL=https://rez-auth.rezapp.com

# External Service APIs
ANALYTICS_API=https://rez-analytics.onrender.com
MERCHANT_API=https://rez-merchant.onrender.com
INTELLIGENCE_API=https://rez-intelligence.onrender.com

# HOJAI Finance AI
HOJAIFINANCE_AI_URL=http://localhost:4830

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
