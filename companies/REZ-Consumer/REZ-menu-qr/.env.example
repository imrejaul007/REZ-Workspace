# ===========================================
# REZ Menu QR Service - Production Config
# ===========================================

# Server
PORT=3018
NODE_ENV=production
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/rez-menu-qr
MONGODB_USER=
MONGODB_PASSWORD=

# Security
INTERNAL_API_KEY=CHANGE_ME_generate_strong_api_key_here

# External Service APIs
REZSCHEDULE_API_URL=https://rez-schedule.rezapp.com

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
