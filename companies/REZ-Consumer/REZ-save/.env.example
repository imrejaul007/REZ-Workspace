# ===========================================
# REZ Save Service - Production Config
# ===========================================

# Server
PORT=3016
NODE_ENV=production
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/rez-save
MONGODB_USER=
MONGODB_PASSWORD=

# Security
INTERNAL_API_KEY=CHANGE_ME_generate_strong_api_key_here

# RABTUL Services
AUTH_SERVICE_URL=https://rez-auth.rezapp.com
WALLET_SERVICE_URL=https://rez-wallet.rezapp.com
INTERNAL_SERVICE_TOKEN=CHANGE_ME_generate_strong_token_here

# External Service APIs
INTELLIGENCE_API=https://rez-intelligence.onrender.com
AGENT_API=https://REZ-agent.onrender.com

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
