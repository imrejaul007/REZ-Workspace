# ===========================================
# REZ Bills Service - Production Config
# ===========================================

# Server
PORT=3012
NODE_ENV=production
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/rez-bills
MONGODB_USER=
MONGODB_PASSWORD=

# Security
INTERNAL_API_KEY=CHANGE_ME_generate_strong_api_key_here

# RABTUL Services
RABTUL_AUTH_URL=https://rez-auth.rezapp.com
RABTUL_WALLET_URL=https://rez-wallet.rezapp.com
RABTUL_VERIFY_URL=https://rez-verify.rezapp.com
RABTUL_NOTIFICATION_URL=https://rez-notification.rezapp.com

# External Service APIs
ANALYTICS_API=https://rez-analytics.rezapp.com

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
