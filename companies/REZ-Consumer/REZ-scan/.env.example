# ===========================================
# REZ Scan Service - Production Config
# ===========================================

# Server
PORT=3017
NODE_ENV=production
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/rez-scan
MONGODB_USER=
MONGODB_PASSWORD=

# Security
INTERNAL_API_KEY=CHANGE_ME_generate_strong_api_key_here

# External Service APIs
INTENT_API=https://rez-intent-graph.onrender.com
VERIFY_API=https://rez-verify-qr.onrender.com
AGENT_API=https://REZ-agent.onrender.com
INTELLIGENCE_API=https://rez-intelligence.onrender.com

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
