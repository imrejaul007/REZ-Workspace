{
  "name": "rez-scan",
  "version": "1.0.2",
  "description": "REZ Universal QR Scanner - Scan any QR code with MongoDB, WebSocket, RABTUL rewards",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "PORT=3017 npx tsx src/index.ts",
    "dev:watch": "PORT=3017 npx ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "PORT=3017 node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": ["qr", "scanner", "barcode", "websocket", "rez"],
  "author": "REZ Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "geoip-lite": "^1.2.2",
    "helmet": "^8.2.0",
    "mongoose": "^8.0.0",
    "socket.io": "^4.7.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}