# ===========================================
# REZ Nearby Service - Production Config
# ===========================================

# Server
PORT=3014
NODE_ENV=production
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://localhost:27017/rez-nearby
MONGODB_USER=
MONGODB_PASSWORD=

# Security
INTERNAL_API_KEY=CHANGE_ME_generate_strong_api_key_here

# External Service APIs
INTELLIGENCE_API=https://rez-intelligence.onrender.com
MERCHANT_API=https://rez-merchant.onrender.com

# Maps (for location services)
MAPBOX_API_KEY=
GOOGLE_MAPS_API_KEY=

# Sentry (Error Tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
