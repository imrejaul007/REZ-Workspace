# AssetMind Environment Configuration
# Copy to .env and fill in all values

# =============================================================================
# SECURITY - CRITICAL (MUST BE SET IN PRODUCTION)
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ASSETMIND_SECRET_KEY=

# Demo user (only used in development - leave empty in production)
ASSETMIND_DEMO_EMAIL=
ASSETMIND_DEMO_PASSWORD=

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgresql://assetmind:assetmind@localhost:5432/assetmind
DATABASE_URL_TEST=postgresql://assetmind:assetmind@localhost:5432/assetmind_test
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Neo4j (Knowledge Graph)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# TimescaleDB
TIMESCALEDB_URL=postgresql://assetmind:assetmind@localhost:5433/assetmind

# =============================================================================
# EXTERNAL APIs (Get keys from respective services)
# =============================================================================
API_KEY=
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
COINGECKO_API_KEY=
SEC_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
DUNE_API_KEY=

# Yahoo Finance
YAHOO_FINANCE_ENABLED=true

# =============================================================================
# APPLICATION
# =============================================================================
APP_ENV=development
LOG_LEVEL=INFO
DEBUG=false

# =============================================================================
# SECURITY
# =============================================================================
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# =============================================================================
# CORS (Comma-separated list of allowed origins)
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# WEBSOCKET
# =============================================================================
WS_PING_INTERVAL=30
WS_PING_TIMEOUT=10

# =============================================================================
# AGENT ORCHESTRATOR
# =============================================================================
ORCHESTRATOR_URL=http://localhost:5090

# =============================================================================
# MEMORY PLATFORM (HOJAI)
# =============================================================================
HOJAI_MEMORY_URL=http://localhost:4540
HOJAI_MEMORY_API_KEY=

# =============================================================================
# RABTUL INTEGRATION
# =============================================================================
RABTUL_AUTH_URL=https://auth.rabtul.com
RABTUL_WALLET_URL=https://wallet.rabtul.com
RABTUL_API_KEY=

