# Environment Variables for GENIE Slack Service

# Server Configuration
PORT=4711
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/genie-slack

# CORS Origins
CORS_ORIGINS=*

# Slack OAuth Configuration
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_REDIRECT_URI=https://your-domain.com/api/slack/oauth

# GENIE Service URLs
GENIE_MEMORY_SERVICE_URL=http://localhost:4703
GENIE_RELATIONSHIP_SERVICE_URL=http://localhost:4702
