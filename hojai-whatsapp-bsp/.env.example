PORT=4890
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/hojai_whatsapp_bsp

# WhatsApp Business API (Meta)
WHATSAPP_API_VERSION=v18.0
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_APP_SECRET=your-app-secret

# Webhook
WEBHOOK_VERIFY_TOKEN=your-verify-token
WEBHOOK_CALLBACK_URL=https://your-domain.com/webhook/whatsapp

# Services
HOJAI_STUDIO_URL=http://localhost:4850
HOJAI_UNIFIED_INBOX_URL=http://localhost:4870

# Internal Auth
INTERNAL_SERVICE_TOKEN=your-internal-token

# Rate Limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
